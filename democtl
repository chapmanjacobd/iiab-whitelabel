###############################################################################
# democtl stop
###############################################################################
cmd_stop() {
    ensure_root "$@"
    if [ $# -eq 0 ]; then
        echo "Error: at least one demo name required" >&2
        echo "Usage: democtl stop <name> [name ...]" >&2
        return 1
    fi

    local exit_code=0
    for name in "$@"; do
        local demo_dir="$ACTIVE_DIR/$name"
        if [ ! -d "$demo_dir" ]; then
            echo "Error: demo '$name' not found" >&2
            exit_code=1
            continue
        fi

        local status
        status=$(cat "$demo_dir/status" 2>/dev/null || echo "unknown")

        case "$status" in
            running|starting|stopping)
                ;;
            stopped)
                echo "Demo '$name' is already stopped."
                continue
                ;;
            building|pending)
                echo "Error: demo '$name' is being built (status: $status). Use 'democtl remove $name' to cancel." >&2
                exit_code=1
                continue
                ;;
            failed)
                echo "Error: demo '$name' has failed. Use 'democtl remove $name' to clean up." >&2
                exit_code=1
                continue
                ;;
            *)
                echo "Error: demo '$name' has unknown status '$status'." >&2
                exit_code=1
                continue
                ;;
        esac

        echo "Stopping demo '$name' (was: $status)..."
        echo "stopping" > "$demo_dir/status"
        if ! systemctl stop "systemd-nspawn@${name}.service" 2>/dev/null; then
            echo "Warning: Could not stop systemd-nspawn@${name}.service (may not be running)"
        fi
        if ! systemctl disable "systemd-nspawn@${name}.service" 2>/dev/null; then
            echo "Warning: Could not disable systemd-nspawn@${name}.service (may not be registered)"
        fi
        echo "stopped" > "$demo_dir/status"
        echo "Demo '$name' has been stopped."
    done
    return $exit_code
}

###############################################################################
# Helper: Wait for container to reach running substate
###############################################################################
_wait_for_running() {
    local name="$1"
    local poll_max=60

    sleep 3
    local poll_count=0
    local container_active=false
    local non_running_count=0
    while [ $poll_count -lt $poll_max ]; do
        local substate=""
        substate=$(systemctl show "systemd-nspawn@${name}.service" --property=SubState --value 2>/dev/null || echo "")
        if [ "$substate" = "running" ]; then
            container_active=true
            break
        fi
        non_running_count=$((non_running_count + 1))
        if [ "$non_running_count" -ge 3 ] && { [ "$substate" = "auto-restart" ] || [ "$substate" = "failed" ]; }; then
            break
        fi
        poll_count=$((poll_count + 1))
        sleep 1
    done

    if ! $container_active; then
        return 1
    fi
    return 0
}

###############################################################################
# democtl start
###############################################################################
cmd_start() {
    ensure_root "$@"
    if [ $# -eq 0 ]; then
        echo "Error: at least one demo name required" >&2
        echo "Usage: democtl start <name> [name ...]" >&2
        return 1
    fi

    local exit_code=0
    for name in "$@"; do
        local demo_dir="$ACTIVE_DIR/$name"
        if [ ! -d "$demo_dir" ]; then
            echo "Error: demo '$name' not found" >&2
            exit_code=1
            continue
        fi

        local status
        status=$(cat "$demo_dir/status" 2>/dev/null || echo "unknown")

        if [ "$status" = "running" ]; then
            echo "Error: demo '$name' is already running" >&2
            exit_code=1
            continue
        fi

        # Ensure rootfs symlink exists
        if [ ! -e "/var/lib/machines/$name" ]; then
            echo "Error: Rootfs not found for demo '$name'" >&2
            echo "  Build it first: democtl build $name" >&2
            exit_code=1
            continue
        fi

        echo "Starting demo '$name'..."
        echo "starting" > "$demo_dir/status"
        systemctl daemon-reload
        if ! systemctl enable --now "systemd-nspawn@${name}.service" 2>/dev/null; then
            echo "Warning: systemctl enable --now returned non-zero (container may still start, polling for status...)"
        fi

        if ! _wait_for_running "$name"; then
            echo "Error: Container did not become active within 60s" >&2
            log_demo "$name" "--- systemd-nspawn@${name}.service state ---"
            systemctl show "systemd-nspawn@${name}.service" --property=ActiveState,SubState,ExecMainStatus 2>&1 || true
            log_demo "$name" "--- journal (last 30 lines) ---"
            journalctl -u "systemd-nspawn@${name}.service" --no-pager -n 30 2>&1 || true
            echo "failed" > "$demo_dir/status"
            exit_code=1
            continue
        fi

        # Regenerate nginx config and apply network isolation after successful start
        log_demo "$name" "Updating nginx configuration..."
        if [ -x "$SCRIPT_DIR/nginx-gen.sh" ]; then
            bash "$SCRIPT_DIR/nginx-gen.sh"
        fi

        log_demo "$name" "Ensuring network isolation rules..."
        add_container_isolation

        echo "running" > "$demo_dir/status"
        echo "Demo '$name' is now running!"
    done
    return $exit_code
}

###############################################################################
# democtl restart
###############################################################################
cmd_restart() {
    ensure_root "$@"
    if [ $# -eq 0 ]; then
        echo "Error: at least one demo name required" >&2
        echo "Usage: democtl restart <name> [name ...]" >&2
        return 1
    fi

    local exit_code=0
    for name in "$@"; do
        local demo_dir="$ACTIVE_DIR/$name"
        if [ ! -d "$demo_dir" ]; then
            echo "Error: demo '$name' not found" >&2
            exit_code=1
            continue
        fi

        local status
        status=$(cat "$demo_dir/status" 2>/dev/null || echo "unknown")

        if [ "$status" != "running" ]; then
            echo "Error: demo '$name' is not running (status: $status)" >&2
            exit_code=1
            continue
        fi

        echo "Restarting demo '$name'..."
        echo "restarting" > "$demo_dir/status"
        systemctl restart "systemd-nspawn@${name}.service"

        if ! _wait_for_running "$name"; then
            echo "Error: Container did not become active within 60s after restart" >&2
            log_demo "$name" "--- journal (last 30 lines) ---"
            journalctl -u "systemd-nspawn@${name}.service" --no-pager -n 30 2>&1 || true
            echo "failed" > "$demo_dir/status"
            exit_code=1
            continue
        fi

        # Container is running -- regenerate nginx and reapply isolation
        if [ -x "$SCRIPT_DIR/nginx-gen.sh" ]; then
            bash "$SCRIPT_DIR/nginx-gen.sh"
        fi
        add_container_isolation

        echo "running" > "$demo_dir/status"
        echo "Demo '$name' has been restarted and is running!"
    done
    return $exit_code
}

###############################################################################
# democtl help
###############################################################################
cmd_help() {
    cat << 'EOF'
democtl - Manage IIAB whitelabel demo containers

Usage: democtl <command> [args]

Commands:
  init                          Bootstrap host (install packages, network, nginx)
  build <name> [flags]          Build a demo (leaves it stopped; use --start to bring online)
  remove <name> [name ...]      Stop and delete demo(s)
  rebuild <name> [name ...]     Remove and re-build demo(s)
  rebuild --all                 Rebuild ALL demos from scratch (fresh storage + Debian base)
  list                          Show all demos
  status <name> [name ...]      Detailed status for demo(s)
  logs <name> [name ...]        Show build log or container journal for demo(s)
  shell <name>                  Open shell in container
  stop <name> [name ...]        Stop running demo(s)
  start <name> [name ...]       Start stopped demo(s)
  restart <name> [name ...]     Restart running demo(s)
  reload                        Regenerate nginx config from active demos
  settle [timeout]              Wait until all demos reach a settled state (running/stopped/failed)
  reconcile                     Fix resource counter drift and check ghost IPs

Build flags:
  --repo <url>              IIAB git repo (default: github.com/iiab/iiab.git)
  --branch <ref>            Git branch/tag/ref (default: master)
  --size <MB>               Image capacity (default: 15000)
  --volatile <mode>         no | overlay | state | yes (default: overlay)
  --local-vars <path>       Path to local_vars.yml (host path or relative to cwd; falls back to IIAB repo)
  --wildcard                Use as wildcard for unknown subdomains
  --description <text>      Human-readable description
  --base <path|name>        Build on top of existing base subvolume
  --build-on-disk           Store in /var/ instead of /run/ tmpfs (default: /run/)
  --start                   Start the demo after build completes (default: leave stopped)
  --fg                      Build in foreground (default: background)

Examples:
  democtl init
  democtl build small --local-vars vars/local_vars_small.yml --size 12000
  democtl build pr3612 --local-vars vars/local_vars_large.yml --branch refs/pull/3612/head --volatile yes
  democtl build mydemo --base medium-base --start    # build on top of existing base
  democtl build mydemo --start    # build and immediately start
  democtl list
  democtl status small
  democtl stop small
  democtl start small
  democtl restart small
  democtl remove pr3612
  democtl start small medium large
EOF
}

###############################################################################
# Main dispatch
###############################################################################
main() {
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        init)      cmd_init "$@" ;;
        build)     cmd_build "$@" ;;
        remove)    cmd_remove "$@" ;;
        rebuild)   cmd_rebuild "$@" ;;
        list)      cmd_list "$@" ;;
        status)    cmd_status "$@" ;;
        logs)      cmd_logs "$@" ;;
        shell)     cmd_shell "$@" ;;
        stop)      cmd_stop "$@" ;;
        start)     cmd_start "$@" ;;
        restart)   cmd_restart "$@" ;;
        reload)    cmd_reload "$@" ;;
        settle)    cmd_settle "$@" ;;
        reconcile) cmd_reconcile "$@" ;;
        help|--help|-h) cmd_help ;;
        *)
            echo "Error: Unknown command: $cmd" >&2
            echo "Run 'democtl help' for usage" >&2
            return 1
            ;;
    esac
}

# Only run main when executed directly, not when sourced
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
