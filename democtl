#!/usr/bin/env bash
# democtl - Manage IIAB whitelabel demo containers
# Usage: democtl <command> [args]
set -euo pipefail

###############################################################################
# Constants and state paths
###############################################################################
STATE_DIR="/var/lib/iiab-demos"
ACTIVE_DIR="$STATE_DIR/active"
RESOURCE_FILE="$STATE_DIR/resources"
DEMO_SUBNET="10.0.3.0/24"
# shellcheck disable=SC2034  # Used for documentation/reference
DEMO_GW="10.0.3.1"
SUBNET_BASE="10.0.3"
# shellcheck disable=SC2034  # Reserved for future use / external scripts
BRIDGE="iiab-br0"

# Resource allocation constants
RAM_BUFFER=512    # Extra MB buffer per build (RAM or ram-image) for container runtime
DISK_BASE=0       # No extra disk headroom; use requested size exactly

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/scripts"

# shellcheck source=scripts/lib-iiab.sh disable=SC1091
source "$SCRIPT_DIR/lib-iiab.sh"

###############################################################################
# Flock-based resource protection
###############################################################################
LOCK_FILE="$STATE_DIR/.democtl.lock"
LOCK_FD=200

# Acquire an exclusive lock. Non-blocking by default — errors out immediately
# if the lock is held, so concurrent adds fail cleanly instead of racing.
acquire_lock() {
    local timeout="${1:--1}"  # -1 = wait forever, 0 = non-blocking
    eval "exec $LOCK_FD>$LOCK_FILE"

    # Stale lock detection: verify the lock-holding process is actually a democtl
    _try_clean_stale_lock() {
        if [ -f "$LOCK_FILE" ]; then
            local stale_pid=""
            stale_pid=$(cat "$LOCK_FILE.pid" 2>/dev/null || echo "")
            if [ -n "$stale_pid" ] && [ "$stale_pid" -gt 1 ] 2>/dev/null; then
                # Check if process exists
                if ! kill -0 "$stale_pid" 2>/dev/null; then
                    echo "Warning: Lock held by dead PID $stale_pid, removing stale lock" >&2
                    rm -f "$LOCK_FILE" "$LOCK_FILE.pid"
                    return 0  # Caller should retry
                fi
                # Process exists — verify it's actually a democtl process (avoid PID reuse false positives)
                local cmdline=""
                cmdline=$(tr '\0' ' ' < "/proc/$stale_pid/cmdline" 2>/dev/null || echo "")
                if [ -n "$cmdline" ] && ! echo "$cmdline" | grep -q 'democtl'; then
                    # Process exists but is NOT democtl — likely PID reuse, treat as stale
                    local lock_age
                    lock_age=$(( $(date +%s) - $(stat -c%Y "$LOCK_FILE" 2>/dev/null || date +%s) ))
                    if [ "$lock_age" -gt 300 ]; then  # Only override if lock is > 5 min old
                        echo "Warning: Lock held by non-democtl PID $stale_pid (age: ${lock_age}s), removing stale lock" >&2
                        rm -f "$LOCK_FILE" "$LOCK_FILE.pid"
                        return 0
                    fi
                fi
            fi
        fi
        return 1  # No stale lock or process still alive (and is democtl)
    }

    if [ "$timeout" = "0" ]; then
        if ! flock -n "$LOCK_FD"; then
            # Attempt stale lock cleanup
            if _try_clean_stale_lock; then
                eval "exec $LOCK_FD>$LOCK_FILE"
                if ! flock -n "$LOCK_FD"; then
                    echo "Error: another democtl operation is in progress (lock held)." >&2
                    echo "  If no other democtl is running, remove stale lock:" >&2
                    echo "    rm -f $LOCK_FILE" >&2
                    return 1
                fi
            else
                echo "Error: another democtl operation is in progress (lock held)." >&2
                echo "  If no other democtl is running, remove stale lock:" >&2
                echo "    rm -f $LOCK_FILE $LOCK_FILE.pid" >&2
                return 1
            fi
        fi
    else
        # For blocking mode, periodically check for stale locks
        if [ "$timeout" = "-1" ]; then
            local retries=0
            while ! flock -n "$LOCK_FD" 2>/dev/null; do
                if _try_clean_stale_lock; then
                    eval "exec $LOCK_FD>$LOCK_FILE"
                    if flock -n "$LOCK_FD"; then
                        break
                    fi
                fi
                retries=$((retries + 1))
                if [ "$retries" -ge 60 ]; then
                    echo "Error: Could not acquire lock after 5 minutes" >&2
                    echo "  If no other democtl is running, remove stale lock:" >&2
                    echo "    rm -f $LOCK_FILE $LOCK_FILE.pid" >&2
                    return 1
                fi
                sleep 5
            done
        else
            flock -w "$timeout" "$LOCK_FD"
        fi
    fi

    # Record our PID for stale lock detection by subsequent callers
    echo $$ > "$LOCK_FILE.pid"
}

release_lock() {
    flock -u "$LOCK_FD" 2>/dev/null || true
}

###############################################################################
# Utility functions
###############################################################################

ensure_state_dirs() {
    mkdir -p "$STATE_DIR" "$ACTIVE_DIR"
    if [ ! -f "$RESOURCE_FILE" ]; then
        local disk_total ram_total
        disk_total=$(df -m /var/lib/machines 2>/dev/null | awk 'NR==2 {print $2}' || echo 50000)
        ram_total=$(awk '/MemTotal/ {print int($2/1024)}' /proc/meminfo)
        cat > "$RESOURCE_FILE" << EOF
DISK_TOTAL=${disk_total}
DISK_ALLOCATED=0
RAM_TOTAL=${ram_total}
RAM_ALLOCATED=0
EOF
    fi
}

load_resources() {
    # shellcheck source=/dev/null
    source "$RESOURCE_FILE"
}

save_resources() {
    cat > "$RESOURCE_FILE" << EOF
DISK_TOTAL=${DISK_TOTAL:-0}
DISK_ALLOCATED=${DISK_ALLOCATED:-0}
RAM_TOTAL=${RAM_TOTAL:-0}
RAM_ALLOCATED=${RAM_ALLOCATED:-0}
EOF
}

# Parse a demo config file and set variables
load_demo_config() {
    local name="$1"
    local dir="$ACTIVE_DIR/$name"
    if [ ! -f "$dir/config" ]; then
        echo "Error: No config found for demo '$name'" >&2
        return 1
    fi
    # shellcheck source=/dev/null
    source "$dir/config"
    # These variables are set for external use / reference
    # shellcheck disable=SC2034
    DEMO_NAME="$name"
    # shellcheck disable=SC2034
    DEMO_IP=$(cat "$dir/ip")
    # shellcheck disable=SC2034
    DEMO_STATUS=$(cat "$dir/status" 2>/dev/null || echo "unknown")
}

# Get the next available IP in the subnet. MUST be called under lock.
next_ip() {
    local used_ips=()
    if [ -d "$ACTIVE_DIR" ]; then
        while IFS= read -r ip_file; do
            used_ips+=("$(cat "$ip_file")")
        done < <(find "$ACTIVE_DIR" -name ip -type f 2>/dev/null)
    fi

    local used_count=${#used_ips[@]}
    if [ "$used_count" -gt 0 ]; then
        local remaining=$(( 253 - used_count ))
        if [ "$remaining" -lt 10 ]; then
            echo "Warning: Subnet pool running low — ${used_count}/253 IPs used, ${remaining} remaining" >&2
        fi
    fi

    for i in $(seq 2 254); do
        local candidate="${SUBNET_BASE}.${i}"
        local in_use=false
        for used in "${used_ips[@]+"${used_ips[@]}"}"; do
            if [ "$used" = "$candidate" ]; then
                in_use=true
                break
            fi
        done
        if ! $in_use; then
            echo "$candidate"
            return 0
        fi
    done
    echo "Error: No available IPs in ${DEMO_SUBNET} (all 253 addresses in use)" >&2
    return 1
}

log_demo() {
    local name="$1"
    shift
    echo "[$(date -u +%H:%M:%S)] [$name] $*"
}

# Validate that a script exists, is executable, and has no syntax errors
_validate_script() {
    local script="$1"
    if [ ! -f "$script" ]; then
        echo "Error: Script not found: $script" >&2
        return 1
    fi
    if [ ! -x "$script" ]; then
        echo "Error: Script not executable: $script" >&2
        return 1
    fi
    if ! bash -n "$script" 2>/dev/null; then
        echo "Error: Script has syntax errors: $script" >&2
        return 1
    fi
    return 0
}

###############################################################################
# Resource pre-flight checks (MUST be called under lock)
###############################################################################
check_resources() {
    local name="$1"
    local size_mb="$2"
    local ram_image="$3"

    load_resources

    # All demos build in RAM (tmpfs) — check available RAM for the build
    local ram_avail=$(( RAM_TOTAL - RAM_ALLOCATED - RAM_BUFFER ))
    local ram_needed=$(( size_mb + RAM_BUFFER ))
    if [ "$ram_needed" -gt "$ram_avail" ]; then
        echo "Error: Insufficient RAM to build demo '$name'." >&2
        echo "  Need: ~${ram_needed}MB (demo: ${size_mb}MB + ${RAM_BUFFER}MB buffer)" >&2
        echo "  Available: ${ram_avail}MB (${RAM_TOTAL}MB total - ${RAM_ALLOCATED}MB allocated)" >&2
        echo "" >&2
        echo "  Options:" >&2
        echo "    Remove some demos: democtl remove <name>" >&2
        echo "    Free all RAMFS: democtl ramfs cleanup" >&2
        return 1
    fi

    # Non-ram-image demos also need persistent disk for the final image (after build)
    if ! $ram_image; then
        local disk_avail
        disk_avail=$(df -m /var/lib/machines 2>/dev/null | awk 'NR==2 {print $4}' || echo 0)
        local disk_needed=$(( size_mb + DISK_BASE ))
        if [ "$disk_needed" -gt "$disk_avail" ]; then
            echo "Error: Insufficient disk space for demo '$name' (final image)." >&2
            echo "  Need: ~${disk_needed}MB (image: ${size_mb}MB + overhead)" >&2
            echo "  Available: ${disk_avail}MB" >&2
            return 1
        fi
    else
        # RAM-image demos need a small amount of disk for the base image (shared, one-time)
        local disk_avail
        disk_avail=$(df -m /var/lib/machines 2>/dev/null | awk 'NR==2 {print $4}' || echo 0)
        local base_disk_needed=$(( DISK_BASE + 500 ))
        if [ "$base_disk_needed" -gt "$disk_avail" ]; then
            echo "Error: Insufficient disk space for base image." >&2
            echo "  Need: ~${base_disk_needed}MB" >&2
            echo "  Available: ${disk_avail}MB" >&2
            return 1
        fi
    fi
    return 0
}

allocate_resources() {
    local name="$1"
    local size_mb="$2"
    local ram_image="$3"

    load_resources
    if $ram_image; then
        RAM_ALLOCATED=$(( RAM_ALLOCATED + size_mb ))
    else
        DISK_ALLOCATED=$(( DISK_ALLOCATED + size_mb ))
    fi
    save_resources
}

free_resources() {
    local name="$1"

    local dir="$ACTIVE_DIR/$name"
    if [ -f "$dir/config" ]; then
        # shellcheck source=/dev/null
        local ram_image=false
        if grep -q '^RAM_IMAGE=true$' "$dir/config" 2>/dev/null; then
            ram_image=true
        fi
        local size_mb=0
        if grep -q '^IMAGE_SIZE_MB=' "$dir/config" 2>/dev/null; then
            size_mb=$(grep '^IMAGE_SIZE_MB=' "$dir/config" | cut -d= -f2)
        fi

        load_resources
        if $ram_image; then
            RAM_ALLOCATED=$(( RAM_ALLOCATED - size_mb ))
            if [ "$RAM_ALLOCATED" -lt 0 ]; then
                RAM_ALLOCATED=0
            fi
        else
            DISK_ALLOCATED=$(( DISK_ALLOCATED - size_mb ))
            if [ "$DISK_ALLOCATED" -lt 0 ]; then
                DISK_ALLOCATED=0
            fi
        fi
        save_resources
    fi
}

###############################################################################
# democtl init
###############################################################################
cmd_init() {
    ensure_root "$@"
    echo "=== Initializing IIAB demo server host ==="
    if [ -f "$SCRIPT_DIR/host-setup.sh" ]; then
        bash "$SCRIPT_DIR/host-setup.sh"
    else
        echo "Error: host-setup.sh not found at $SCRIPT_DIR" >&2
        return 1
    fi
    ensure_state_dirs
    echo ""
    echo "Host initialized. Now add demos with:"
    echo "  democtl add small --local-vars vars/local_vars_small.yml --size 12000"
    echo "  make small medium large"
}

###############################################################################
# democtl add
###############################################################################
cmd_add() {
    ensure_root "$@"

    # Defaults
    local name="" branch="master"
    local repo="https://github.com/iiab/iiab.git"
    local size_mb=15000 volatile="state" ram_image=true
    local local_vars="" wildcard=false description=""
    local foreground=false build_on_disk=false skip_install=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            add) shift ;;  # skip 'add' from parsed args
            --branch)     branch="$2"; shift 2 ;;
            --repo)       repo="$2"; shift 2 ;;
            --size)       size_mb="$2"; shift 2 ;;
            --volatile)   volatile="$2"; shift 2 ;;
            --disk-backed) ram_image=false; shift ;;
            --ram-image)  ram_image=true; shift ;;  # keep as hidden/legacy alias
            --local-vars) local_vars="$2"; shift 2 ;;
            --wildcard)   wildcard=true; shift ;;
            --description) description="$2"; shift 2 ;;
            --build-on-disk) build_on_disk=true; shift ;;
            --skip-install) skip_install=true; shift ;;
            --fg)         foreground=true; shift ;;
            *)
                if [ -z "$name" ]; then
                    name="$1"; shift
                else
                    echo "Warning: Unknown argument: $1" >&2
                    shift
                fi
                ;;
        esac
    done

    # Normalize repo URL: add https:// if missing
    if [[ "$repo" == github.com/* ]]; then
        repo="https://$repo"
    fi

    if [ -z "$name" ]; then
        echo "Error: demo name required" >&2
        echo "Usage: democtl add <name> [--branch <branch>] ..." >&2
        return 1
    fi

    # Validate demo name: only letters, numbers, hyphens, underscores; max 64 chars
    if [[ ! "$name" =~ ^[a-zA-Z0-9_-]+$ ]]; then
        echo "Error: Demo name '$name' contains invalid characters." >&2
        echo "  Only letters, numbers, hyphens, and underscores are allowed." >&2
        return 1
    fi
    if [[ ${#name} -gt 64 ]]; then
        echo "Error: Demo name must be 64 characters or less (got ${#name})." >&2
        return 1
    fi

    # Validate size is a positive integer and reasonable (>= 1000 MB)
    if [[ ! "$size_mb" =~ ^[0-9]+$ ]] || [ "$size_mb" -lt 1000 ]; then
        echo "Error: --size must be a positive integer >= 1000 MB (got: $size_mb)." >&2
        return 1
    fi

    # Validate local-vars path exists early (before acquiring lock)
    if [ -n "$local_vars" ] && [[ "$local_vars" == /* ]] && [ ! -f "$local_vars" ]; then
        echo "Error: local-vars file not found: $local_vars" >&2
        return 1
    fi

    ensure_state_dirs

    # Acquire lock for: check resources → allocate → assign IP → write config
    acquire_lock 0 || return 1
    trap release_lock EXIT

    # Check if demo already exists (under lock)
    if [ -d "$ACTIVE_DIR/$name" ]; then
        echo "Error: demo '$name' already exists. Use 'democtl rebuild $name' to recreate." >&2
        release_lock
        trap - EXIT
        return 1
    fi

    # Resource pre-flight (under lock)
    if ! check_resources "$name" "$size_mb" "$ram_image"; then
        release_lock
        trap - EXIT
        return 1
    fi

    # Allocate resources (under lock)
    allocate_resources "$name" "$size_mb" "$ram_image"

    # Assign IP (under lock)
    local ip
    ip=$(next_ip)

    # Create demo directory structure (under lock)
    local demo_dir="$ACTIVE_DIR/$name"
    mkdir -p "$demo_dir"

    # Write config (under lock)
    cat > "$demo_dir/config" << EOF
DEMO_NAME="$name"
IIAB_REPO="$repo"
IIAB_BRANCH="$branch"
IMAGE_SIZE_MB=$size_mb
VOLATILE="$volatile"
RAM_IMAGE=$ram_image
BUILD_ON_DISK=$build_on_disk
SKIP_INSTALL=$skip_install
LOCAL_VARS="$local_vars"
WILDCARD=$wildcard
DESCRIPTION="$description"
EOF

    echo "$ip" > "$demo_dir/ip"
    echo "pending" > "$demo_dir/status"
    echo "" > "$demo_dir/build.log"

    # Release lock — the build runs independently now
    release_lock
    trap - EXIT

    echo "Demo '$name' queued (subdomain: ${name}.iiab.io, IP: $ip)"

    if $foreground; then
        build_demo "$name"
    else
        # Fork build in background with heartbeat monitoring
        (
            build_demo "$name" >> "$demo_dir/build.log" 2>&1
        ) &
        local pid=$!
        echo "$pid" > "$demo_dir/build.pid"

        # Fork heartbeat watchdog
        (
            set +e  # Don't exit on errors, handle them gracefully
            local last_size=0
            local stale_count=0
            local max_stale=12  # 12 checks × 5min = 60 min max staleness
            while kill -0 "$pid" 2>/dev/null; do
                sleep 300  # Check every 5 minutes
                if [ -f "$demo_dir/build.log" ]; then
                    local current_size
                    current_size=$(stat -c%s "$demo_dir/build.log" 2>/dev/null || echo 0)
                    if [ "$current_size" -eq "$last_size" ] && [ "$last_size" -gt 0 ]; then
                        stale_count=$((stale_count + 1))
                        if [ "$stale_count" -ge "$max_stale" ]; then
                            echo "[$(date -u +%H:%M:%S)] [watchdog] Build appears hung (no log output in $(( stale_count * 5 )) min). Killing PID $pid" >> "$demo_dir/build.log"
                            kill -TERM "$pid" 2>/dev/null
                            sleep 10
                            if kill -0 "$pid" 2>/dev/null; then
                                kill -9 "$pid" 2>/dev/null || true
                            fi
                            sleep 5
                            # Wait for build process to actually exit
                            local wait_count=0
                            while kill -0 "$pid" 2>/dev/null && [ "$wait_count" -lt 30 ]; do
                                sleep 1
                                wait_count=$((wait_count + 1))
                            done
                            echo "failed" > "$demo_dir/status"
                            # Rollback resources
                            if acquire_lock 0; then
                                free_resources "$name"
                                release_lock
                            fi
                            rm -f "$demo_dir/build.pid" "$demo_dir/build.watchdog"
                            break
                        fi
                    else
                        last_size="$current_size"
                        stale_count=0
                    fi
                fi
            done
            # Clean up watchdog file when exiting naturally
            rm -f "$demo_dir/build.watchdog"
        ) &
        local watchdog_pid=$!
        echo "$watchdog_pid" > "$demo_dir/build.watchdog"

        echo "Build started in background (PID: $pid, watchdog: $watchdog_pid)"
        echo "  democtl status $name   # Check progress"
        echo "  democtl logs $name     # Follow build log"
    fi
}

###############################################################################
# build_demo — background build process
###############################################################################
build_demo() {
    local name="$1"
    local demo_dir="$ACTIVE_DIR/$name"

    log_demo "$name" "Starting build..."
    echo "building" > "$demo_dir/status"

    # Load config
    # shellcheck source=/dev/null
    source "$demo_dir/config"

    local ip
    ip=$(cat "$demo_dir/ip")

    # Build the container image using build-container.sh
    local build_script="${SCRIPT_DIR}/build-container.sh"

    # Validate all external scripts before use
    if ! _validate_script "$build_script"; then
        log_demo "$name" "Error: build-container.sh validation failed"
        echo "failed" > "$demo_dir/status"
        _rollback_build_resources "$name"
        return 1
    fi

    # Resource pre-flight (re-check under lock — resources may have changed since add)
    if ! acquire_lock 0; then
        log_demo "$name" "Warning: Could not acquire lock for resource re-check"
    else
        # shellcheck disable=SC2153  # Variables are set via source from config file
        if ! check_resources "$name" "$IMAGE_SIZE_MB" "$RAM_IMAGE"; then
            log_demo "$name" "Resources no longer available, aborting build"
            release_lock
            echo "failed" > "$demo_dir/status"
            _rollback_build_resources "$name"
            return 1
        fi
        release_lock
    fi

    # shellcheck disable=SC2153
    local build_args=(
        "--name" "$name"
        "--repo" "$IIAB_REPO"
        "--branch" "$IIAB_BRANCH"
        "--size" "$IMAGE_SIZE_MB"
        "--volatile" "$VOLATILE"
        "--ip" "$ip"
    )

    if [ "$RAM_IMAGE" = "true" ]; then
        build_args+=("--ram-image")
    fi

    if [ "${BUILD_ON_DISK:-false}" = "true" ]; then
        build_args+=("--build-on-disk")
    fi

    if [ "${SKIP_INSTALL:-false}" = "true" ]; then
        build_args+=("--skip-install")
    fi

    if [ -n "$LOCAL_VARS" ]; then
        build_args+=("--local-vars" "$LOCAL_VARS")
    fi

    log_demo "$name" "Building: branch=$IIAB_BRANCH volatile=$VOLATILE ram_image=$RAM_IMAGE"
    log_demo "$name" "This will take 30-60 minutes..."

    if ! bash "$build_script" "${build_args[@]}"; then
        log_demo "$name" "Build FAILED!"
        echo "failed" > "$demo_dir/status"
        _rollback_build_resources "$name"
        return 1
    fi

    # Create .nspawn service files
    local service_script="${SCRIPT_DIR}/container-service.sh"
    local svc_args=("$name" "$ip" "--volatile=$VOLATILE")
    if [ "$RAM_IMAGE" = "true" ]; then
        svc_args+=("--ram-image")
    fi

    if [ -x "$service_script" ]; then
        bash "$service_script" "${svc_args[@]}"
    fi

    # Register and start with systemd
    local image_path
    if [ "$RAM_IMAGE" = "true" ] && [ -f "/run/iiab-ramfs/${name}.raw" ]; then
        image_path="/run/iiab-ramfs/${name}.raw"
        # For systemd-nspawn@.service to find it, symlink to /var/lib/machines
        ln -sf "$image_path" "/var/lib/machines/${name}.raw"
    else
        image_path="/var/lib/machines/${name}.raw"
    fi

    if [ ! -f "$image_path" ]; then
        log_demo "$name" "Error: Image not found at $image_path"
        echo "failed" > "$demo_dir/status"
        _rollback_build_resources "$name"
        return 1
    fi

    log_demo "$name" "Starting container via systemd-nspawn@${name}.service..."
    systemctl daemon-reload
    systemctl enable --now "systemd-nspawn@${name}.service" 2>/dev/null || true

    # Poll for actual container startup (nspawn can fail asynchronously)
    # We check SubState on the nspawn service itself, not the machine scope.
    sleep 3
    local poll_count=0
    local poll_max=20
    local container_active=false
    while [ $poll_count -lt $poll_max ]; do
        local active="" substate=""
        active=$(systemctl show "systemd-nspawn@${name}.service" --property=ActiveState --value 2>/dev/null || echo "")
        substate=$(systemctl show "systemd-nspawn@${name}.service" --property=SubState --value 2>/dev/null || echo "")
        # Handle both stripped and non-stripped values (older systemd)
        if [ "$substate" = "running" ] || [[ "$substate" == *"=running" ]]; then
            container_active=true
            break
        fi
        # Also catch crash-looping: active=activating with substate=auto-restart
        if [ "$substate" = "auto-restart" ] || [[ "$substate" == *"=auto-restart" ]]; then
            break
        fi
        poll_count=$((poll_count + 1))
        sleep 1
    done

    if ! $container_active; then
        log_demo "$name" "Error: Container did not start successfully within ${poll_max}s"
        log_demo "$name" "--- systemd-nspawn@${name}.service state ---"
        systemctl show "systemd-nspawn@${name}.service" --property=ActiveState,SubState,ExecMainStatus 2>&1 || true
        log_demo "$name" "--- journalctl _COMM=systemd-nspawn (last 30 lines) ---"
        journalctl _COMM=systemd-nspawn --no-pager -n 30 2>&1 || true
        log_demo "$name" "--- Full journal for nspawn@${name}.service (last 50 lines) ---"
        journalctl -u "systemd-nspawn@${name}.service" --no-pager -n 50 2>&1 || true
        echo "failed" > "$demo_dir/status"
        _rollback_build_resources "$name"
        return 1
    fi

    # Regenerate nginx
    log_demo "$name" "Updating nginx configuration..."
    if [ -x "$SCRIPT_DIR/nginx-gen.sh" ]; then
        bash "$SCRIPT_DIR/nginx-gen.sh"
    fi

    # Apply network isolation rules (global, idempotent)
    log_demo "$name" "Ensuring network isolation rules..."
    add_container_isolation

    echo "running" > "$demo_dir/status"
    rm -f "$demo_dir/build.pid"  # Build complete, clear PID
    log_demo "$name" "Demo is now running!"
}

# Rollback resources when a build fails
_rollback_build_resources() {
    local name="$1"
    local demo_dir="$ACTIVE_DIR/$name"

    # Acquire lock to safely modify resource counters
    if acquire_lock 0; then
        free_resources "$name"
        release_lock
    else
        log_demo "$name" "Warning: Could not acquire lock to rollback resources"
    fi

    # Clean up build PID file
    rm -f "$demo_dir/build.pid"
}

###############################################################################
# democtl remove
###############################################################################
cmd_remove() {
    ensure_root "$@"
    local name="${1:?Error: demo name required}"

    local demo_dir="$ACTIVE_DIR/$name"
    if [ ! -d "$demo_dir" ]; then
        echo "Error: demo '$name' not found" >&2
        return 1
    fi

    echo "Removing demo '$name'..."

    # Stop container
    systemctl stop "systemd-nspawn@${name}.service" 2>/dev/null || true
    systemctl disable "systemd-nspawn@${name}.service" 2>/dev/null || true

    # Kill any running build and watchdog
    if [ -f "$demo_dir/build.watchdog" ]; then
        local wpid
        wpid=$(cat "$demo_dir/build.watchdog")
        kill "$wpid" 2>/dev/null || true
        rm -f "$demo_dir/build.watchdog"
    fi
    if [ -f "$demo_dir/build.pid" ]; then
        local pid
        pid=$(cat "$demo_dir/build.pid")
        kill "$pid" 2>/dev/null || true
        rm -f "$demo_dir/build.pid"
    fi

    # Acquire lock for: read config → free resources → cleanup
    acquire_lock 0 || return 1
    trap release_lock EXIT

    # Free resources (under lock)
    free_resources "$name"

    # Remove from RAMFS if loaded
    if [ -x "$SCRIPT_DIR/ramfs-setup.sh" ]; then
        bash "$SCRIPT_DIR/ramfs-setup.sh" unload "$name" 2>/dev/null || true
    fi

    # Remove image and symlinks
    rm -f "/var/lib/machines/${name}.raw"
    rm -f "/run/iiab-ramfs/${name}.raw"

    # Remove .nspawn config
    rm -f "/etc/systemd/nspawn/${name}.nspawn"
    rm -rf "/etc/systemd/system/systemd-nspawn@${name}.service.d"

    # Remove demo state (under lock — last step frees the IP slot)
    rm -rf "$demo_dir"

    # Release lock
    release_lock
    trap - EXIT

    echo "Demo '$name' removed."

    # Reload systemd
    systemctl daemon-reload

    # Regenerate nginx
    if [ -x "$SCRIPT_DIR/nginx-gen.sh" ]; then
        bash "$SCRIPT_DIR/nginx-gen.sh"
    fi
}

###############################################################################
# democtl rebuild
###############################################################################
cmd_rebuild() {
    ensure_root "$@"
    local name="${1:?Error: demo name required}"

    # Save config before removing
    local demo_dir="$ACTIVE_DIR/$name"
    if [ ! -d "$demo_dir" ] || [ ! -f "$demo_dir/config" ]; then
        echo "Error: demo '$name' not found" >&2
        return 1
    fi

    local saved_config
    saved_config=$(cat "$demo_dir/config")

    cmd_remove "$name"

    # Re-add with saved config
    echo "$saved_config" | while IFS='=' read -r key value; do
        case "$key" in
            IIAB_BRANCH)   branch="$value" ;;
            IIAB_REPO)     repo="$value" ;;
            IMAGE_SIZE_MB) size_mb="$value" ;;
            VOLATILE)      volatile="$value" ;;
            RAM_IMAGE)     ram_image=$value ;;
            BUILD_ON_DISK) build_on_disk=$value ;;
            SKIP_INSTALL)  skip_install=$value ;;
            LOCAL_VARS)    local_vars="$value" ;;
            WILDCARD)      wildcard=$value ;;
            DESCRIPTION)   description="$value" ;;
        esac
    done

    local add_args=("$name")
    [ -n "${branch:-}" ] && add_args+=("--branch" "$branch")
    [ -n "${repo:-}" ] && add_args+=("--repo" "$repo")
    [ -n "${size_mb:-}" ] && add_args+=("--size" "${size_mb:-15000}")
    [ -n "${volatile:-}" ] && add_args+=("--volatile" "${volatile:-state}")
    [ "${ram_image:-true}" = "false" ] && add_args+=("--disk-backed")
    [ "${build_on_disk:-false}" = "true" ] && add_args+=("--build-on-disk")
    [ "${skip_install:-false}" = "true" ] && add_args+=("--skip-install")
    [ -n "${local_vars:-}" ] && add_args+=("--local-vars" "$local_vars")
    [ "${wildcard:-false}" = "true" ] && add_args+=("--wildcard")
    [ -n "${description:-}" ] && add_args+=("--description" "$description")

    cmd_add "${add_args[@]}"
}

###############################################################################
# democtl list
###############################################################################
cmd_list() {
    ensure_root "$@"
    ensure_state_dirs

    # Load resources
    load_resources

    printf "%-15s %-20s %-12s %-10s %-10s %s\n" \
        "NAME" "SUBDOMAIN" "IP" "STATUS" "RAM/MB" "DESCRIPTION"
    printf "%-15s %-20s %-12s %-10s %-10s %s\n" \
        "----" "---------" "--" "------" "------" "-----------"

    local total_ram_used=0
    for demo_dir in "$ACTIVE_DIR"/*/; do
        [ -d "$demo_dir" ] || continue
        local name
        name=$(basename "$demo_dir")
        # shellcheck source=/dev/null
        source "$demo_dir/config"
        local ip
        ip=$(cat "$demo_dir/ip" 2>/dev/null || echo "?")
        local status
        status=$(cat "$demo_dir/status" 2>/dev/null || echo "unknown")
        local ram_display="-"
        if [ "$RAM_IMAGE" = "true" ]; then
            ram_display="${IMAGE_SIZE_MB}M"
            total_ram_used=$(( total_ram_used + IMAGE_SIZE_MB ))
        fi
        local desc="${DESCRIPTION:--}"
        printf "%-15s %-20s %-12s %-10s %-10s %s\n" \
            "$name" "${SUBDOMAIN:-$name}.iiab.io" "$ip" "$status" "$ram_display" "$desc"
    done

    echo ""
    echo "Resources: ${RAM_ALLOCATED}MB/${RAM_TOTAL}MB RAM allocated, ${DISK_ALLOCATED}MB disk"
}

###############################################################################
# democtl status
###############################################################################
cmd_status() {
    ensure_root "$@"
    local name="${1:?Error: demo name required}"
    local demo_dir="$ACTIVE_DIR/$name"

    if [ ! -d "$demo_dir" ]; then
        echo "Error: demo '$name' not found" >&2
        return 1
    fi

    # shellcheck source=/dev/null
    source "$demo_dir/config"
    local ip
    ip=$(cat "$demo_dir/ip")
    local status
    status=$(cat "$demo_dir/status" 2>/dev/null || echo "unknown")

    echo "=== Demo: $name ==="
    echo "Subdomain:  ${name}.iiab.io"
    echo "Branch:     $IIAB_BRANCH"
    echo "Repo:       $IIAB_REPO"
    echo "IP:         $ip"
    echo "Status:     $status"
    echo "Volatile:   $VOLATILE"
    echo "RAM Image:  $RAM_IMAGE"
    echo "Size:       ${IMAGE_SIZE_MB}MB"
    if [ -n "$DESCRIPTION" ]; then
        echo "Description: $DESCRIPTION"
    fi

    if [ "$status" = "running" ]; then
        echo ""
        systemctl status "systemd-nspawn@${name}.service" --no-pager || true
    fi

    # Show certificate expiry info
    local subdomain
    subdomain=$(sanitize_subdomain "${SUBDOMAIN:-$name}" 2>/dev/null || echo "${SUBDOMAIN:-$name}")
    local cert_path="/etc/letsencrypt/live/${subdomain}.iiab.io/fullchain.pem"
    if [ -f "$cert_path" ]; then
        local cert_expiry
        cert_expiry=$(openssl x509 -enddate -noout -in "$cert_path" 2>/dev/null | cut -d= -f2 || echo "")
        if [ -n "$cert_expiry" ]; then
            local expiry_epoch now days_left
            expiry_epoch=$(date -d "$cert_expiry" +%s 2>/dev/null || echo 0)
            now=$(date +%s)
            if [ "$expiry_epoch" -gt 0 ]; then
                days_left=$(( (expiry_epoch - now) / 86400 ))
                echo ""
                echo "Certificate: $cert_path"
                echo "  Expires: $cert_expiry"
                if [ "$days_left" -lt 0 ]; then
                    echo "  Status: EXPIRED ($(( -days_left )) days ago)"
                elif [ "$days_left" -lt 7 ]; then
                    echo "  Status: WARNING — expires in $days_left days"
                else
                    echo "  Status: OK ($days_left days remaining)"
                fi
            fi
        fi
    elif [ "$status" = "running" ]; then
        echo ""
        echo "Certificate: not obtained (run: democtl certbot)"
    fi

    if [ "$status" = "building" ] && [ -f "$demo_dir/build.pid" ]; then
        local pid
        pid=$(cat "$demo_dir/build.pid")
        echo ""
        echo "Build PID: $pid"
        if kill -0 "$pid" 2>/dev/null; then
            echo "Build is still running..."
        else
            echo "Build process has exited (check log)"
        fi

        # Show watchdog info
        if [ -f "$demo_dir/build.watchdog" ]; then
            local wpid
            wpid=$(cat "$demo_dir/build.watchdog")
            if kill -0 "$wpid" 2>/dev/null; then
                echo "Watchdog PID: $wpid (monitoring)"
            else
                echo "Watchdog PID: $wpid (exited)"
            fi
        fi

        # Check for hung build (no log output in 30+ minutes)
        if [ -f "$demo_dir/build.log" ]; then
            local log_mtime now age_sec
            log_mtime=$(stat -c%Y "$demo_dir/build.log" 2>/dev/null || echo 0)
            now=$(date +%s)
            age_sec=$(( now - log_mtime ))
            if [ "$age_sec" -gt 1800 ]; then
                echo ""
                echo "WARNING: Build log hasn't been updated for $(( age_sec / 60 )) minutes."
                echo "  The build may be hung. Consider: democtl remove $name"
            fi
        fi
    fi
}

###############################################################################
# democtl logs
###############################################################################
cmd_logs() {
    ensure_root "$@"
    local name="${1:?Error: demo name required}"
    local demo_dir="$ACTIVE_DIR/$name"

    if [ ! -d "$demo_dir" ]; then
        echo "Error: demo '$name' not found" >&2
        return 1
    fi

    local status
    status=$(cat "$demo_dir/status" 2>/dev/null || echo "unknown")

    if [ "$status" = "running" ]; then
        journalctl -u "systemd-nspawn@${name}.service" -e --no-pager
    elif [ -f "$demo_dir/build.log" ]; then
        echo "=== Build log for '$name' ==="
        tail -100 "$demo_dir/build.log"
    else
        echo "No logs available for '$name'"
    fi
}

###############################################################################
# democtl shell
###############################################################################
cmd_shell() {
    ensure_root "$@"
    local name="${1:?Error: demo name required}"

    if [ ! -d "$ACTIVE_DIR/$name" ]; then
