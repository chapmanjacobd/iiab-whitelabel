###############################################################################
# democtl apply — read demos.sh and ensure state
###############################################################################
cmd_apply() {
    ensure_root "$@"
    local config_file="${1:-demos.sh}"

    if [ ! -f "$config_file" ]; then
        echo "Error: config file not found: $config_file" >&2
        return 1
    fi

    ensure_state_dirs

    echo "=== Applying demo configuration from $config_file ==="

    # Parse the config file: collect all "demo add <name>" entries
    local -a demo_names=()
    local -a demo_args=()

    # Safely parse the config file by unfolding multi-line statements
    local parse_output
    parse_output=$(sed -e ':a' -e '/\\$/N; s/\\\n[[:space:]]*/ /; ta' "$config_file" | awk '/^[[:space:]]*demo add / { $1=""; $2=""; sub(/^[[:space:]]+/, ""); print }')

    while IFS= read -r line; do
        [ -z "$line" ] && continue
        # The first word is the name, rest are flags
        local demo_name
        demo_name=$(echo "$line" | awk '{print $1}')
        demo_names+=("$demo_name")
        demo_args+=("$line")
    done <<< "$parse_output"

    if [ ${#demo_names[@]} -eq 0 ]; then
        echo "No demos found in $config_file"
        return 0
    fi

    echo "Found ${#demo_names[@]} demo(s): ${demo_names[*]}"
    echo ""

    # Add missing demos
    for i in "${!demo_names[@]}"; do
        local name="${demo_names[$i]}"
        local args="${demo_args[$i]}"

        if [ -d "$ACTIVE_DIR/$name" ]; then
            echo "Demo '$name' already exists, skipping"
        else
            echo "Adding demo '$name'..."
            # Parse the args string and call cmd_add
            # shellcheck disable=SC2086
            cmd_add $args
        fi
    done

    # Remove demos not in config
    for demo_dir in "$ACTIVE_DIR"/*/; do
        [ -d "$demo_dir" ] || continue
        local existing_name
        existing_name=$(basename "$demo_dir")
        local found=false
        for wanted in "${demo_names[@]}"; do
            if [ "$existing_name" = "$wanted" ]; then
                found=true
                break
            fi
        done
        if ! $found; then
            echo "Removing demo '$existing_name' (not in config)..."
            cmd_remove "$existing_name"
        fi
    done

    # Regenerate nginx
    echo ""
    echo "Regenerating nginx configuration..."
    if [ -x "$SCRIPT_DIR/nginx-gen.sh" ]; then
        bash "$SCRIPT_DIR/nginx-gen.sh"
    fi

    echo ""
    echo "=== Applied ==="
    cmd_list
}

###############################################################################
# democtl reconcile — fix drift in allocated resource counters
###############################################################################
cmd_reconcile() {
    ensure_root "$@"
    ensure_state_dirs

    echo "=== Reconciling resource counters ==="

    acquire_lock 0 || {
        echo "Error: another operation is in progress" >&2
        return 1
    }
    trap release_lock EXIT

    load_resources

    local old_disk_allocated="$DISK_ALLOCATED"
    local old_ram_allocated="$RAM_ALLOCATED"
    local new_disk_allocated=0
    local new_ram_allocated=0
    local reconciled=0

    for demo_dir in "$ACTIVE_DIR"/*/; do
        [ -d "$demo_dir" ] || continue
        local name
        name=$(basename "$demo_dir")

        if [ ! -f "$demo_dir/config" ]; then
            echo "  Warning: $name has no config file, skipping"
            continue
        fi

        # shellcheck source=/dev/null
        source "$demo_dir/config"

        local size_mb=0
        if [ -n "${IMAGE_SIZE_MB:-}" ]; then
            size_mb="$IMAGE_SIZE_MB"
        fi

        if [ "${RAM_IMAGE:-false}" = "true" ]; then
            new_ram_allocated=$(( new_ram_allocated + size_mb ))
        else
            new_disk_allocated=$(( new_disk_allocated + size_mb ))
        fi
        reconciled=$((reconciled + 1))
    done

    DISK_ALLOCATED="$new_disk_allocated"
    RAM_ALLOCATED="$new_ram_allocated"
    save_resources

    release_lock
    trap - EXIT

    echo "Reconciled $reconciled demo(s)."
    echo "  Disk allocated: ${old_disk_allocated}MB → ${new_disk_allocated}MB"
    echo "  RAM allocated:  ${old_ram_allocated}MB → ${new_ram_allocated}MB"

    # Check for ghost IPs (IPs assigned but no running container)
    echo ""
    echo "=== Checking for ghost IP assignments ==="
    local ghosts=0
    for demo_dir in "$ACTIVE_DIR"/*/; do
        [ -d "$demo_dir" ] || continue
        local name
        name=$(basename "$demo_dir")
        local ip=""
        if [ -f "$demo_dir/ip" ]; then
            ip=$(cat "$demo_dir/ip")
        fi
        local status=""
        if [ -f "$demo_dir/status" ]; then
            status=$(cat "$demo_dir/status")
        fi
        if [ "$status" != "running" ] && [ -n "$ip" ]; then
            echo "  Ghost: $name has IP $ip but status is '$status'"
            ghosts=$((ghosts + 1))
        fi
    done
    if [ "$ghosts" -eq 0 ]; then
        echo "  No ghost IP assignments found."
    fi
}

