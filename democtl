###############################################################################
# democtl settle -- wait until all demos reach a settled state
###############################################################################
cmd_settle() {
    ensure_root "$@"
    local timeout="${1:-3600}"  # Default: wait up to 60 minutes
    ensure_state_dirs

    echo "=== Waiting for all demos to reach a settled state ==="
    echo "  Settled states: running, stopped, failed"
    echo "  Timeout: ${timeout}s"

    local start_time
    start_time=$(date +%s)
    local poll_interval=10

    while true; do
        local now
        now=$(date +%s)
        local elapsed=$(( now - start_time ))

        if [ "$elapsed" -ge "$timeout" ]; then
            echo ""
            echo "Error: Timed out after ${timeout}s waiting for demos to settle." >&2
            echo "  Some demos may still be in transition. Check with: democtl list" >&2
            return 1
        fi

        local all_settled=true
        local in_progress=()
        local failed=()
        local running=0
        local stopped=0

        for demo_dir in "$ACTIVE_DIR"/*/; do
            [ -d "$demo_dir" ] || continue
            local name
            name=$(basename "$demo_dir")
            local status
            status=$(cat "$demo_dir/status" 2>/dev/null || echo "unknown")

            case "$status" in
                running)
                    running=$((running + 1))
                    ;;
                stopped)
                    stopped=$((stopped + 1))
                    ;;
                failed)
                    failed+=("$name")
                    ;;
                pending|building|starting|stopping)
                    all_settled=false
                    in_progress+=("$name")
                    ;;
                *)
                    all_settled=false
                    in_progress+=("$name")
                    ;;
            esac
        done

        # Show progress
        local total=$(( running + stopped + ${#in_progress[@]} + ${#failed[@]} ))
        if [ "$total" -eq 0 ]; then
            echo "No demos found. Nothing to settle."
            return 0
        fi

        echo -ne "\r  Running: $running | Stopped: $stopped | In Progress: ${#in_progress[@]} | Failed: ${#failed[@]} | Elapsed: ${elapsed}s  "

        if $all_settled; then
            echo ""
            echo ""
            echo "All demos have settled."
            echo "  Running: $running"
            echo "  Stopped: $stopped"
            if [ ${#failed[@]} -gt 0 ]; then
                echo "  Failed: ${failed[*]}"
                return 1
            fi
            return 0
        fi

        sleep "$poll_interval"
    done
}

###############################################################################
# democtl reconcile -- fix drift in allocated resource counters
###############################################################################
cmd_reconcile() {
    ensure_root "$@"
    ensure_state_dirs

    echo "=== Reconciling resource counters ==="

    acquire_lock 0 || {
        echo "Error: another operation is in progress" >&2
        return 1
    }

    # load_resources dynamically calculates allocations from active configs
    load_resources
    save_resources

    release_lock

    echo "Reconciled resource allocations from active demos."
    echo "  Disk allocated: ${DISK_ALLOCATED}MB"

    # Check for ghost IPs (IPs assigned but no running container)
    echo ""
    echo "=== Checking for ghost IP assignments ==="
    local ghosts=0
    for demo_dir in "$ACTIVE_DIR"/*/; do
        [ -d "$demo_dir" ] || continue
        local name
        name=$(basename "$demo_dir")
        local ip=""
        if [ -f "$demo_dir/ip" ]; then
            ip=$(cat "$demo_dir/ip")
        fi
        local status=""
        if [ -f "$demo_dir/status" ]; then
            status=$(cat "$demo_dir/status")
        fi
        if [ "$status" != "running" ] && [ -n "$ip" ]; then
            echo "  Ghost: $name has IP $ip but status is '$status'"
            ghosts=$((ghosts + 1))
        fi
    done
    if [ "$ghosts" -eq 0 ]; then
        echo "  No ghost IP assignments found."
    fi
}

