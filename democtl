###############################################################################
# democtl ramfs
###############################################################################
cmd_ramfs() {
    ensure_root "$@"
    local action="${1:?Usage: democtl ramfs <load|unload|status|cleanup> [name]}"
    shift

    if [ -x "$SCRIPT_DIR/ramfs-setup.sh" ]; then
        bash "$SCRIPT_DIR/ramfs-setup.sh" "$action" "$@"
