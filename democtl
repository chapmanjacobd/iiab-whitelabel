cmd_reload() {
    ensure_root "$@"
    if [ -x "$SCRIPT_DIR/nginx-gen.sh" ]; then
        bash "$SCRIPT_DIR/nginx-gen.sh"
    else
        echo "Error: nginx-gen.sh not found at $SCRIPT_DIR/nginx-gen.sh" >&2
