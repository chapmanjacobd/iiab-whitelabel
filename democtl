###############################################################################
# democtl status
###############################################################################
cmd_status() {
    ensure_root "$@"
    if [ $# -eq 0 ]; then
        echo "Error: at least one demo name required" >&2
        echo "Usage: democtl status <name> [name ...]" >&2
        return 1
    fi

    local exit_code=0
    for name in "$@"; do
        local demo_dir="$ACTIVE_DIR/$name"

        if [ ! -d "$demo_dir" ]; then
            echo "Error: demo '$name' not found" >&2
            exit_code=1
            continue
        fi

        # shellcheck source=/dev/null
        source "$demo_dir/config"
        local ip
        ip=$(cat "$demo_dir/ip")
        local status
        status=$(cat "$demo_dir/status" 2>/dev/null || echo "unknown")

        echo "=== Demo: $name ==="
        local status_subdomain
        status_subdomain=$(sanitize_subdomain "${SUBDOMAIN:-$name}")
        echo "Subdomain:  ${status_subdomain}.iiab.io"
        echo "Branch:     $IIAB_BRANCH"
        echo "Repo:       $IIAB_REPO"
        echo "IP:         $ip"
        echo "Status:     $status"
        echo "Volatile:   $VOLATILE"
        echo "RAM Image:  $RAM_IMAGE"
        echo "Size:       ${IMAGE_SIZE_MB}MB"
        if [ -n "$DESCRIPTION" ]; then
            echo "Description: $DESCRIPTION"
        fi

        if [ "$status" = "running" ]; then
            echo ""
            systemctl status "systemd-nspawn@${name}.service" --no-pager || true
        fi

        # Show certificate expiry info
        local subdomain
        subdomain=$(sanitize_subdomain "${SUBDOMAIN:-$name}" 2>/dev/null || echo "${SUBDOMAIN:-$name}")
        local cert_path="/etc/letsencrypt/live/${subdomain}.iiab.io/fullchain.pem"
        if [ -f "$cert_path" ]; then
            local cert_expiry
            cert_expiry=$(openssl x509 -enddate -noout -in "$cert_path" 2>/dev/null | cut -d= -f2 || echo "")
            if [ -n "$cert_expiry" ]; then
                local expiry_epoch now days_left
                expiry_epoch=$(date -d "$cert_expiry" +%s 2>/dev/null || echo 0)
                now=$(date +%s)
                if [ "$expiry_epoch" -gt 0 ]; then
                    days_left=$(( (expiry_epoch - now) / 86400 ))
                    echo ""
                    echo "Certificate: $cert_path"
                    echo "  Expires: $cert_expiry"
                    if [ "$days_left" -lt 0 ]; then
                        echo "  Status: EXPIRED ($(( -days_left )) days ago)"
                    elif [ "$days_left" -lt 7 ]; then
                        echo "  Status: WARNING -- expires in $days_left days"
                    else
                        echo "  Status: OK ($days_left days remaining)"
                    fi
                fi
            fi
        elif [ "$status" = "running" ]; then
            echo ""
            echo "Certificate: not obtained (run: democtl certbot)"
        fi

        if [ "$status" = "building" ] && [ -f "$demo_dir/build.pid" ]; then
            local pid
            pid=$(cat "$demo_dir/build.pid")
            echo ""
            echo "Build PID: $pid"
            if kill -0 "$pid" 2>/dev/null; then
                echo "Build is still running..."
            else
                echo "Build process has exited (check log)"
            fi

            # Show watchdog info
            if [ -f "$demo_dir/build.watchdog" ]; then
                local wpid
                wpid=$(cat "$demo_dir/build.watchdog")
                if kill -0 "$wpid" 2>/dev/null; then
                    echo "Watchdog PID: $wpid (monitoring)"
                else
                    echo "Watchdog PID: $wpid (exited)"
                fi
            fi

            # Check for hung build (no log output in 30+ minutes)
            if [ -f "$demo_dir/build.log" ]; then
                local log_mtime now age_sec
                log_mtime=$(stat -c%Y "$demo_dir/build.log" 2>/dev/null || echo 0)
                now=$(date +%s)
                age_sec=$(( now - log_mtime ))
                if [ "$age_sec" -gt 1800 ]; then
                    echo ""
                    echo "WARNING: Build log hasn't been updated for $(( age_sec / 60 )) minutes."
                    echo "  The build may be hung. Consider: democtl remove $name"
                fi
            fi
        fi

        # Separate output for multiple demos
        if [ $# -gt 1 ]; then
            echo ""
        fi
    done
    return $exit_code
}

