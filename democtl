#!/usr/bin/env bash
# democtl - Manage IIAB whitelabel demo containers
# Usage: democtl <command> [args]
set -euo pipefail

# Save original script path and arguments before any function shifts them.
# Used by ensure_root() in lib-iiab.sh for correct re-execution.
_DEMOCTL_SCRIPT="$(readlink -f "$0")"
# shellcheck disable=SC2034
_DEMOCTL_ORIG_ARGS=("$@")

###############################################################################
# Constants and state paths
###############################################################################
STATE_DIR="/var/lib/iiab-demos"
ACTIVE_DIR="$STATE_DIR/active"
RESOURCE_FILE="$STATE_DIR/resources"
# Network config is defined in scripts/lib-iiab.sh (IIAB_DEMO_SUBNET, IIAB_SUBNET_BASE, etc.)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/scripts"

# shellcheck source=scripts/lib-iiab.sh disable=SC1091
source "$SCRIPT_DIR/lib-iiab.sh"

# Alias for backward compatibility within this script
DEMO_SUBNET="$IIAB_DEMO_SUBNET"
SUBNET_BASE="$IIAB_SUBNET_BASE"

# Resource allocation constants
DISK_BASE=100     # Extra MB headroom per build (btrfs metadata + buffer)

###############################################################################
# Flock-based resource protection
###############################################################################
LOCK_FILE="$STATE_DIR/.democtl.lock"
LOCK_FD=200

# Acquire an exclusive lock.
# flock releases automatically when the process dies -- no PID tracking needed.
acquire_lock() {
    local timeout="${1:--1}"  # -1 = wait forever, 0 = non-blocking
    eval "exec $LOCK_FD>>$LOCK_FILE"

    if [ "$timeout" = "0" ]; then
        if ! flock -n "$LOCK_FD"; then
            echo "Error: another democtl operation is in progress (lock held)." >&2
            return 1
        fi
    else
        if [ "$timeout" = "-1" ]; then
            if ! flock "$LOCK_FD"; then
                echo "Error: Could not acquire lock" >&2
                return 1
            fi
        else
            if ! flock -w "$timeout" "$LOCK_FD"; then
                echo "Error: Could not acquire lock after ${timeout}s" >&2
                return 1
            fi
        fi
    fi
}

release_lock() {
    flock -u "$LOCK_FD" 2>/dev/null || true
}

# Check if a demo build is currently in progress (PID file exists and process is alive).
# Returns 0 if a build is actively running, 1 otherwise.
is_build_in_progress() {
    local name="$1"
    local demo_dir="$ACTIVE_DIR/$name"
    if [ -f "$demo_dir/build.pid" ]; then
        local pid
        pid=$(cat "$demo_dir/build.pid" 2>/dev/null || true)
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            return 0  # Build is in progress
        fi
    fi
    return 1  # No active build
}

# Clean up a failed build: remove directory, reclaim the IP slot, and clean build artifacts.
# MUST be called under lock.
cleanup_failed_build() {
    local name="$1"
    local demo_dir="$ACTIVE_DIR/$name"
    log_demo "$name" "Cleaning up failed build..."

    # 1. Kill any lingering build/watchdog processes
    if [ -f "$demo_dir/build.watchdog" ]; then
        local wpid
        wpid=$(cat "$demo_dir/build.watchdog" 2>/dev/null || true)
        if [ -n "$wpid" ]; then
            kill "$wpid" 2>/dev/null || true
        fi
        rm -f "$demo_dir/build.watchdog"
    fi
    if [ -f "$demo_dir/build.pid" ]; then
        local pid
        pid=$(cat "$demo_dir/build.pid" 2>/dev/null || true)
        if [ -n "$pid" ]; then
            kill "$pid" 2>/dev/null || true
        fi
        rm -f "$demo_dir/build.pid"
    fi

    # 2. Clean up container resources (machine, veth, subvolume)
    cleanup_demo_resources "$name"

    # 3. Remove demo directory (releases IP slot)
    rm -rf "$demo_dir"

    # Clean up leftover lock files in the builds directory (from flock or external tools)
    local builds_dirs=("/run/iiab-demos/storage/builds" "/var/iiab-demos/storage/builds")
    for bdir in "${builds_dirs[@]}"; do
        if [ -d "$bdir" ]; then
            # Remove emacs-style lock files (.#<name>.lck) and plain .lck files
            rm -f "$bdir/.#${name}.lck" "$bdir/.${name}.lck" "$bdir/${name}.lck"
        fi
    done

    log_demo "$name" "Cleanup complete (directory and IP slot reclaimed)"
}

# Thoroughly clean up container resources: machines, veth interfaces, and subvolumes.
# This is safe to call even if resources are already partially removed.
cleanup_demo_resources() {
    local name="$1"

    # Force-terminate any lingering nspawn machine (essential for cleanup)
    if machinectl show "$name" >/dev/null 2>&1; then
        machinectl terminate "$name" 2>/dev/null || true
        # Wait briefly for termination
        local waited=0
        while machinectl show "$name" >/dev/null 2>&1 && [ "$waited" -lt 5 ]; do
            sleep 0.5
            waited=$((waited + 1))
        done
    fi

    # Clean up any leftover veth interfaces
    ip link delete "ve-${name}" 2>/dev/null || true
    ip link delete "vb-${name}" 2>/dev/null || true

    # Delete the btrfs subvolume if it exists
    local STORAGE_ROOT=""
    if [ -f /run/iiab-demos/storage.btrfs ] && mountpoint -q /run/iiab-demos/storage 2>/dev/null; then
        STORAGE_ROOT="/run/iiab-demos/storage"
    elif [ -f /var/iiab-demos/storage.btrfs ] && mountpoint -q /var/iiab-demos/storage 2>/dev/null; then
        STORAGE_ROOT="/var/iiab-demos/storage"
    fi
    if [ -n "$STORAGE_ROOT" ] && [ -d "$STORAGE_ROOT/builds/$name" ]; then
        # Attempt subvolume deletion with a small retry loop if busy
        local del_count=0
        while ! btrfs subvolume delete --commit-each "$STORAGE_ROOT/builds/$name" >/dev/null 2>&1; do
            [ -d "$STORAGE_ROOT/builds/$name" ] || break
            del_count=$((del_count + 1))
            if [ "$del_count" -ge 5 ]; then
                break
            fi
            sleep 1
        done
    fi

    # Remove image symlink in /var/lib/machines
    rm -f "/var/lib/machines/$name"

    # Remove .nspawn config and service overrides
    rm -f "/etc/systemd/nspawn/${name}.nspawn"
    rm -rf "/etc/systemd/system/systemd-nspawn@${name}.service.d"
}

###############################################################################
# Dynamic storage growth (MUST be called under lock)
###############################################################################
grow_storage() {
    local build_on_disk="$1"
    local needed_mb="$2"

    local STORAGE_BTRFS STORAGE_ROOT
    if [ "$build_on_disk" = "true" ]; then
        STORAGE_BTRFS="/var/iiab-demos/storage.btrfs"
        STORAGE_ROOT="/var/iiab-demos/storage"
    else
        STORAGE_BTRFS="/run/iiab-demos/storage.btrfs"
        STORAGE_ROOT="/run/iiab-demos/storage"
    fi

    # Must be mounted for btrfs filesystem df to work
    if ! mountpoint -q "$STORAGE_ROOT" 2>/dev/null; then
        return 1
    fi

    local current_size_gb=0
    if [ -f "$STORAGE_BTRFS" ]; then
        local size_bytes
        size_bytes=$(stat -c%s "$STORAGE_BTRFS" 2>/dev/null || echo 0)
        current_size_gb=$(( size_bytes / 1073741824 ))
    fi

    local btrfs_used
    btrfs_used=$(btrfs filesystem df "$STORAGE_ROOT" 2>/dev/null | \
        awk '/Data, single/ {match($0, /used=([0-9.]+)([A-Za-z]+)/, a); if (a[2]=="GiB") printf "%d", a[1]*1024; else if (a[2]=="MiB") printf "%d", a[1]; else print 0}' || echo 0)
    local needed_total_mb=$(( ${btrfs_used:-0} + needed_mb + 2048 ))  # 2GB headroom
    local target_gb=$(( (needed_total_mb + 1023) / 1024 ))

    # Enforce a reasonable minimum (matching INITIAL_SIZE_GB in build-container.sh)
    local min_gb=20
    if [ "$target_gb" -lt "$min_gb" ]; then
        target_gb=$min_gb
    fi

    if [ "$target_gb" -le "$current_size_gb" ]; then
        echo "Storage already ${current_size_gb}G (sufficient for ${needed_mb}MB build)"
        return 0
    fi

    # Check if any containers are actively using this storage
    for machine in $(machinectl list --no-legend 2>/dev/null | awk '{print $1}' || true); do
        local root_path
        root_path=$(machinectl show "$machine" -p RootDirectory --value 2>/dev/null || echo "")
        if [[ "$root_path" == "$STORAGE_ROOT"* ]]; then
            echo "Warning: container '$machine' is using storage -- cannot resize" >&2
            return 1
        fi
    done

    echo "Growing ${STORAGE_BTRFS} from ${current_size_gb}G to ${target_gb}G..."
    btrfs filesystem sync "$STORAGE_ROOT" 2>/dev/null || true
    btrfs subvolume sync "$STORAGE_ROOT" 2>/dev/null || true
    sync
    umount "$STORAGE_ROOT"
    truncate -s "${target_gb}G" "$STORAGE_BTRFS"
    if [ "$build_on_disk" = "true" ]; then
        mount -o loop,compress-force=zstd:1,noatime,discard=async "$STORAGE_BTRFS" "$STORAGE_ROOT"
    else
        mount -o loop,noatime "$STORAGE_BTRFS" "$STORAGE_ROOT"
    fi
    echo "Storage grown to ${target_gb}G ($(df -h "$STORAGE_ROOT" | awk 'NR==2 {print $4}') available)"
}

###############################################################################
# Utility functions
###############################################################################

ensure_state_dirs() {
    mkdir -p "$STATE_DIR" "$ACTIVE_DIR" /var/lib/machines
    if [ ! -f "$RESOURCE_FILE" ]; then
        local disk_total
        disk_total=$(df -m /var/lib/machines 2>/dev/null | awk 'NR==2 {print $2}' || echo 50000)
        cat > "$RESOURCE_FILE" << EOF
DISK_TOTAL=${disk_total}
EOF
    fi
}

load_resources() {
    DISK_ALLOCATED=0

    # Ensure state dirs exist before loading
    mkdir -p "$STATE_DIR" "$ACTIVE_DIR"

    if [ -d "$ACTIVE_DIR" ]; then
        for demo_dir in "$ACTIVE_DIR"/*/; do
            [ -d "$demo_dir" ] || continue
            if [ -f "$demo_dir/config" ]; then
                # shellcheck source=/dev/null
                source "$demo_dir/config"
                DISK_ALLOCATED=$(( DISK_ALLOCATED + IMAGE_SIZE_MB ))
            fi
        done
    fi

    # Total system resources (read-only from file)
    if [ -f "$RESOURCE_FILE" ]; then
        # shellcheck source=/dev/null
        source "$RESOURCE_FILE"
    else
        DISK_TOTAL=$(df -m /var/lib/machines 2>/dev/null | awk 'NR==2 {print $2}' || echo 50000)
    fi
}

save_resources() {
    cat > "$RESOURCE_FILE" << EOF
DISK_TOTAL=${DISK_TOTAL:-0}
DISK_ALLOCATED=${DISK_ALLOCATED:-0}
EOF
}

# Parse a demo config file and set variables
load_demo_config() {
    local name="$1"
    local dir="$ACTIVE_DIR/$name"
    if [ ! -f "$dir/config" ]; then
        echo "Error: No config found for demo '$name'" >&2
        return 1
    fi
    # shellcheck source=/dev/null
    source "$dir/config"
    # These variables are set for external use / reference
    # shellcheck disable=SC2034
    DEMO_NAME="$name"
    # shellcheck disable=SC2034
    DEMO_IP=$(cat "$dir/ip")
    # shellcheck disable=SC2034
    DEMO_STATUS=$(cat "$dir/status" 2>/dev/null || echo "unknown")
}

# Get the next available IP in the subnet. MUST be called under lock.
next_ip() {
    local used_ips=()
    if [ -d "$ACTIVE_DIR" ]; then
        while IFS= read -r ip_file; do
            # Skip empty or partially-written ip files (concurrent builds)
            if [ -s "$ip_file" ]; then
                used_ips+=("$(cat "$ip_file")")
            fi
        done < <(find "$ACTIVE_DIR" -name ip -type f 2>/dev/null)
    fi

    local used_count=${#used_ips[@]}
    if [ "$used_count" -gt 0 ]; then
        local remaining=$(( 253 - used_count ))
        if [ "$remaining" -lt 10 ]; then
            echo "Warning: Subnet pool running low -- ${used_count}/253 IPs used, ${remaining} remaining" >&2
        fi
    fi

    for i in $(seq 2 254); do
        local candidate="${SUBNET_BASE}.${i}"
        local in_use=false
        for used in "${used_ips[@]+"${used_ips[@]}"}"; do
            if [ "$used" = "$candidate" ]; then
                in_use=true
                break
            fi
        done
        if ! $in_use; then
            echo "$candidate"
            return 0
        fi
    done
    echo "Error: No available IPs in ${DEMO_SUBNET} (all 253 addresses in use)" >&2
    return 1
}

log_demo() {
    local name="$1"
    shift
    echo "[$(date -u +%H:%M:%S)] [$name] $*"
}

# Validate that a script exists, is executable, and has no syntax errors
_validate_script() {
    local script="$1"
    if [ ! -f "$script" ]; then
        echo "Error: Script not found: $script" >&2
        return 1
    fi
    if [ ! -x "$script" ]; then
        echo "Error: Script not executable: $script" >&2
        return 1
    fi
    if ! bash -n "$script" 2>/dev/null; then
        echo "Error: Script has syntax errors: $script" >&2
        return 1
    fi
    return 0
}

###############################################################################
# Resource pre-flight checks (MUST be called under lock)
###############################################################################
check_resources() {
    local name="$1"
    local size_mb="$2"
    local build_on_disk="$3"

    load_resources

    # Determine available space. When the relevant storage is mounted (loop-mounted
    # sparse btrfs file), df on the mount point is authoritative -- it sees the
    # full virtual size of the sparse file. btrfs filesystem df only reports
    # already-allocated chunks, which underreports available space.
    local storage_avail
    if [ "$build_on_disk" = "true" ]; then
        if mountpoint -q /var/iiab-demos/storage 2>/dev/null; then
            storage_avail=$(df -m /var/iiab-demos/storage 2>/dev/null | awk 'NR==2 {print $4}' || echo 0)
        else
            storage_avail=$(df -m /var 2>/dev/null | awk 'NR==2 {print $4}' || echo 0)
        fi
    else
        if mountpoint -q /run/iiab-demos/storage 2>/dev/null; then
            storage_avail=$(df -m /run/iiab-demos/storage 2>/dev/null | awk 'NR==2 {print $4}' || echo 0)
        else
            # Unmounted tmpfs build -- check available RAM minus existing btrfs file size
            local avail_ram
            avail_ram=$(awk '/MemAvailable/ {print int($2/1024)}' /proc/meminfo)
            local already_allocated=0
            if [ -f /run/iiab-demos/storage.btrfs ]; then
                already_allocated=$(du -sm /run/iiab-demos/storage.btrfs 2>/dev/null | cut -f1 || echo 0)
            fi
            storage_avail=$(( avail_ram - already_allocated ))
        fi
    fi

    local needed=$(( size_mb + DISK_BASE ))
    if [ "$needed" -gt "$storage_avail" ]; then
        echo "Error: Insufficient space to build demo '$name'." >&2
        echo "  Need: ~${needed}MB (demo: ${size_mb}MB + ${DISK_BASE}MB buffer)" >&2
        echo "  Available: ${storage_avail}MB" >&2
        return 1
    fi
    return 0
}

###############################################################################
# democtl init
###############################################################################
cmd_init() {
    ensure_root "$@"
    echo "=== Initializing IIAB demo server host ==="
    if [ -f "$SCRIPT_DIR/host-setup.sh" ]; then
        bash "$SCRIPT_DIR/host-setup.sh"
    else
        echo "Error: host-setup.sh not found at $SCRIPT_DIR" >&2
        return 1
    fi
    ensure_state_dirs
    echo ""
    echo "Host initialized. Now add demos with:"
    echo "  democtl build small --local-vars vars/local_vars_small.yml --size 12000"
    echo "  make small medium large"
}

###############################################################################
# democtl build
###############################################################################
cmd_build() {
    ensure_root "$@"

    # Defaults
    local name="" branch="master"
    local repo="https://github.com/iiab/iiab.git"
    local size_mb=15000 volatile="overlay"
    local local_vars="" wildcard=false description="" base_name=""
    local foreground=false build_on_disk=false skip_install=false
    local start_after_build=false cleanup_failed=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --branch)     branch="$2"; shift 2 ;;
            --repo)       repo="$2"; shift 2 ;;
            --size)       size_mb="$2"; shift 2 ;;
            --volatile)   volatile="$2"; shift 2 ;;
            --local-vars) local_vars="$2"; shift 2 ;;
            --wildcard)   wildcard=true; shift ;;
            --description) description="$2"; shift 2 ;;
            --base)       base_name="$2"; shift 2 ;;
            --disk)       build_on_disk=true; shift ;;
            --build-on-disk) build_on_disk=true; shift ;;  # legacy alias
            --skip-install) skip_install=true; shift ;;
            --cleanup)    cleanup_failed=true; shift ;;
            --start)      start_after_build=true; shift ;;
            --fg)         foreground=true; shift ;;
            *)
                if [ -z "$name" ]; then
                    name="$1"; shift
                else
                    echo "Error: Unknown argument: $1" >&2
                    echo "Usage: democtl build <name> [--branch <branch>] [--start] ..." >&2
                    return 1
                fi
                ;;
        esac
    done

    # Normalize repo URL: add https:// if missing
    if [[ "$repo" == github.com/* ]]; then
        repo="https://$repo"
    fi

    if [ -z "$name" ]; then
        echo "Error: demo name required" >&2
        echo "Usage: democtl build <name> [--branch <branch>] [--start] ..." >&2
        return 1
    fi

    # Validate demo name: only letters, numbers, hyphens, underscores; max 64 chars
    if [[ ! "$name" =~ ^[a-zA-Z0-9_-]+$ ]]; then
        echo "Error: Demo name '$name' contains invalid characters." >&2
        echo "  Only letters, numbers, hyphens, and underscores are allowed." >&2
        return 1
    fi
    if [[ ${#name} -gt 64 ]]; then
        echo "Error: Demo name must be 64 characters or less (got ${#name})." >&2
        return 1
    fi

    # Validate size is a positive integer and reasonable (>= 1000 MB)
    if [[ ! "$size_mb" =~ ^[0-9]+$ ]] || [ "$size_mb" -lt 1000 ]; then
        echo "Error: --size must be a positive integer >= 1000 MB (got: $size_mb)." >&2
        return 1
    fi

    # Validate local-vars path: only check absolute paths exist early (before acquiring lock).
    # Relative paths are deferred to build time -- they may live inside the IIAB repo.
    if [ -n "$local_vars" ] && [[ "$local_vars" == /* ]] && [ ! -f "$local_vars" ]; then
        echo "Error: local-vars file not found: $local_vars" >&2
        return 1
    fi

    # Validate --base subvolume exists (in current or alternate storage)
    if [ -n "$base_name" ] && [[ "$base_name" != /* ]]; then
        local BASE_BTRFS BASE_MOUNT ALT_STORAGE ALT_MOUNT
        if [ "$build_on_disk" = "true" ]; then
            BASE_BTRFS="/var/iiab-demos/storage.btrfs"
            BASE_MOUNT="/var/iiab-demos/storage"
            ALT_STORAGE="/run/iiab-demos/storage.btrfs"
            ALT_MOUNT="/run/iiab-demos/alt-ram-storage"
        else
            BASE_BTRFS="/run/iiab-demos/storage.btrfs"
            BASE_MOUNT="/run/iiab-demos/storage"
            ALT_STORAGE="/var/iiab-demos/storage.btrfs"
            ALT_MOUNT="/var/iiab-demos/alt-disk-storage"
        fi

        local BASE_SUBVOL="builds/$base_name"
        local base_found=false
        if [ -f "$BASE_BTRFS" ] && mountpoint -q "$BASE_MOUNT" 2>/dev/null; then
            if btrfs subvolume show "$BASE_MOUNT/$BASE_SUBVOL" >/dev/null 2>&1; then
                base_found=true
            fi
        fi

        if ! $base_found && [ -f "$ALT_STORAGE" ]; then
            if ! mountpoint -q "$ALT_MOUNT" 2>/dev/null; then
                mkdir -p "$ALT_MOUNT"
                mount -o loop,noatime "$ALT_STORAGE" "$ALT_MOUNT" 2>/dev/null || true
            fi
            if mountpoint -q "$ALT_MOUNT" 2>/dev/null; then
                if btrfs subvolume show "$ALT_MOUNT/$BASE_SUBVOL" >/dev/null 2>&1; then
                    base_found=true
                    echo "Note: Base '$base_name' will be copied from alternate storage ($ALT_STORAGE) during build."
                fi
            fi
            # Clean up temp mount
            umount -l "$ALT_MOUNT" 2>/dev/null || true
            rmdir "$ALT_MOUNT" 2>/dev/null || true
        fi

        if ! $base_found; then
            echo "Error: Base subvolume '$base_name' not found in current or alternate storage." >&2
            echo "  Build the base demo first: democtl build $base_name" >&2
            release_lock
            return 1
        fi
    fi

    ensure_state_dirs

    # Acquire lock for: check resources → allocate → assign IP → write config
    acquire_lock 0 || return 1

    # Check if demo already exists (under lock)
    if [ -d "$ACTIVE_DIR/$name" ]; then
        # Check if this is an interrupted/failed build that can be safely cleaned up
        local status_file="$ACTIVE_DIR/$name/status"
        local status="unknown"
        if [ -f "$status_file" ]; then
            status=$(cat "$status_file" 2>/dev/null || echo "unknown")
        fi

        case "$status" in
            pending|building)
                # Pokeyoke: reject if a build is actively running (PID alive)
                if is_build_in_progress "$name"; then
                    echo "Error: demo '$name' already has an active build in progress (status: $status)." >&2
                    echo "  Use 'democtl status $name' to check progress, or 'democtl delete $name' to cancel." >&2
                    release_lock
                    return 1
                fi
                echo "Warning: demo '$name' has an interrupted build (status: $status, process exited)." >&2
                echo "  Cleaning up failed build and retrying..." >&2
                cleanup_failed_build "$name"
                # Continue with fresh build
                ;;
            failed)
                echo "Warning: demo '$name' previously failed (status: $status)." >&2
                echo "  Cleaning up and retrying..." >&2
                cleanup_failed_build "$name"
                # Continue with fresh build
                ;;
            *)
                echo "Error: demo '$name' already exists (status: $status). Use 'democtl rebuild $name' to recreate." >&2
                release_lock
                return 1
                ;;
        esac
    fi

    # Resource pre-flight (under lock)
    if ! check_resources "$name" "$size_mb" "$build_on_disk"; then
        # Try to grow storage to accommodate the build
        echo "Attempting to grow storage..."
        if grow_storage "$build_on_disk" "$size_mb" && \
           check_resources "$name" "$size_mb" "$build_on_disk"; then
            echo "Storage resized successfully, proceeding with build."
        else
            release_lock
            return 1
        fi
    fi

    # Assign IP (under lock)
    local ip
    ip=$(next_ip)

    # Create demo directory structure (under lock)
    local demo_dir="$ACTIVE_DIR/$name"
    mkdir -p "$demo_dir"

    # Write config (under lock)
    cat > "$demo_dir/config" << EOF
DEMO_NAME="$name"
IIAB_REPO="$repo"
IIAB_BRANCH="$branch"
IMAGE_SIZE_MB=$size_mb
VOLATILE_MODE="$volatile"
BUILD_ON_DISK=$build_on_disk
SKIP_INSTALL=$skip_install
CLEANUP_FAILED=$cleanup_failed
LOCAL_VARS="$local_vars"
WILDCARD=$wildcard
DESCRIPTION="$description"
BASE_NAME="$base_name"
EOF

    echo "$ip" > "$demo_dir/ip"
    echo "pending" > "$demo_dir/status"
    echo "" > "$demo_dir/build.log"

    # Release lock -- the build runs independently now
    release_lock

    local subdomain
    subdomain=$(sanitize_subdomain "${SUBDOMAIN:-$name}")
    echo "Demo '$name' queued (subdomain: ${subdomain}.iiab.io, IP: $ip)"

    if $foreground; then
        build_demo "$name" "$start_after_build"
    else
        # Fork build in background with heartbeat monitoring
        (
            build_demo "$name" "$start_after_build" >> "$demo_dir/build.log" 2>&1
        ) &
        local pid=$!
        echo "$pid" > "$demo_dir/build.pid"

        # Fork heartbeat watchdog
        (
            set +e  # Don't exit on errors, handle them gracefully
            local last_size=0
            local stale_count=0
            local max_stale=12  # 12 checks × 5min = 60 min max staleness
            while kill -0 "$pid" 2>/dev/null; do
                sleep 300  # Check every 5 minutes
                if [ -f "$demo_dir/build.log" ]; then
                    local current_size
                    current_size=$(stat -c%s "$demo_dir/build.log" 2>/dev/null || echo 0)
                    if [ "$current_size" -eq "$last_size" ] && [ "$last_size" -gt 0 ]; then
                        stale_count=$((stale_count + 1))
                        if [ "$stale_count" -ge "$max_stale" ]; then
                            echo "[$(date -u +%H:%M:%S)] [watchdog] Build appears hung (no log output in $(( stale_count * 5 )) min). Killing PID $pid" >> "$demo_dir/build.log"
                            kill -TERM "$pid" 2>/dev/null
                            sleep 10
                            if kill -0 "$pid" 2>/dev/null; then
                                kill -9 "$pid" 2>/dev/null || true
                            fi
                            sleep 5
                            # Wait for build process to actually exit
                            local wait_count=0
                            while kill -0 "$pid" 2>/dev/null && [ "$wait_count" -lt 30 ]; do
                                sleep 1
                                wait_count=$((wait_count + 1))
                            done
                            echo "failed" > "$demo_dir/status"
                            rm -f "$demo_dir/build.pid" "$demo_dir/build.watchdog"
                            break
                        fi
                    else
                        last_size="$current_size"
                        stale_count=0
                    fi
                fi
            done
            # Clean up watchdog file when exiting naturally
            rm -f "$demo_dir/build.watchdog"
        ) &
        local watchdog_pid=$!
        echo "$watchdog_pid" > "$demo_dir/build.watchdog"

        echo "Build started in background (PID: $pid, watchdog: $watchdog_pid)"
        echo "  democtl status $name   # Check progress"
        echo "  democtl logs $name     # Follow build log"
    fi
}

###############################################################################
# build_demo -- background build process
###############################################################################
build_demo() {
    local name="$1"
    local start_after="${2:-false}"
    local demo_dir="$ACTIVE_DIR/$name"

    log_demo "$name" "Starting build..."
    echo "building" > "$demo_dir/status"

    # Load config
    # shellcheck source=/dev/null
    source "$demo_dir/config"

    local ip
    ip=$(cat "$demo_dir/ip")

    # Build the container image using build-container.sh
    local build_script="${SCRIPT_DIR}/build-container.sh"

    # Validate all external scripts before use
    if ! _validate_script "$build_script"; then
        log_demo "$name" "Error: build-container.sh validation failed"
        echo "failed" > "$demo_dir/status"
        return 1
    fi

    # Resource pre-flight (re-check under lock -- resources may have changed since build)
    if ! acquire_lock 10; then
        log_demo "$name" "Error: Could not acquire lock for resource re-check within 10s -- another operation may be in progress"
        echo "failed" > "$demo_dir/status"
        return 1
    fi
    # shellcheck disable=SC2153  # Variables are set via source from config file
    if ! check_resources "$name" "$IMAGE_SIZE_MB" "${BUILD_ON_DISK:-false}"; then
        # Try to grow storage one last time before build
        if ! grow_storage "${BUILD_ON_DISK:-false}" "$IMAGE_SIZE_MB" || \
           ! check_resources "$name" "$IMAGE_SIZE_MB" "${BUILD_ON_DISK:-false}"; then
            log_demo "$name" "Resources no longer available, aborting build"
            cleanup_failed_build "$name"
            release_lock
            return 1
        fi
        log_demo "$name" "Storage grown to accommodate build"
    fi
    release_lock

    # shellcheck disable=SC2153
    local build_args=(
        "--name" "$name"
        "--repo" "$IIAB_REPO"
        "--branch" "$IIAB_BRANCH"
        "--size" "$IMAGE_SIZE_MB"
        "--volatile" "$VOLATILE_MODE"
        "--ip" "$ip"
        "--config" "$demo_dir/config"
    )

    if [ "${BUILD_ON_DISK:-false}" = "true" ]; then
        build_args+=("--build-on-disk")
    fi

    if [ "${SKIP_INSTALL:-false}" = "true" ]; then
        build_args+=("--skip-install")
    fi

    if [ "${CLEANUP_FAILED:-false}" = "true" ]; then
        build_args+=("--cleanup")
    fi

    if [ -n "$LOCAL_VARS" ]; then
        build_args+=("--local-vars" "$LOCAL_VARS")
    fi

    if [ -n "${BASE_NAME:-}" ]; then
        build_args+=("--base" "$BASE_NAME")
    fi

    log_demo "$name" "Building: branch=$IIAB_BRANCH volatile=$VOLATILE_MODE build_on_disk=${BUILD_ON_DISK:-false}"
    log_demo "$name" "This will take 30-60 minutes..."

    if ! bash "$build_script" "${build_args[@]}"; then
        log_demo "$name" "Build FAILED!"
        echo "failed" > "$demo_dir/status"
        return 1
    fi

    # Create .nspawn service files
    local service_script="${SCRIPT_DIR}/container-service.sh"
    local svc_args=("$name" "$ip" "--volatile=$VOLATILE_MODE")

    if [ -x "$service_script" ]; then
        bash "$service_script" "${svc_args[@]}"
    fi

    # Image is built and service files are created, but do NOT start yet.
    # Write 'stopped' as the final state for a completed build.
    echo "stopped" > "$demo_dir/status"
    rm -f "$demo_dir/build.pid"  # Build complete, clear PID
    log_demo "$name" "Build complete (status: stopped). Use 'democtl start $name' to bring online."

    # If --start was requested, bring the container online now.
    if [ "$start_after" = "true" ]; then
        cmd_start "$name"
    fi
}

###############################################################################
# democtl delete
###############################################################################
cmd_delete() {
    ensure_root "$@"

    local delete_all=false
    local names=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all) delete_all=true; shift ;;
            *) names+=("$1"); shift ;;
        esac
    done

    if $delete_all; then
        for demo_dir in "$ACTIVE_DIR"/*/; do
            [ -d "$demo_dir" ] || continue
            names+=("$(basename "$demo_dir")")
        done
    fi

    if [ ${#names[@]} -eq 0 ]; then
        echo "Error: at least one demo name required" >&2
        echo "Usage: democtl delete <name> [name ...] [--all]" >&2
        return 1
    fi

    local exit_code=0
    for name in "${names[@]}"; do
        local demo_dir="$ACTIVE_DIR/$name"
        if [ ! -d "$demo_dir" ]; then
            echo "Error: demo '$name' not found" >&2
            exit_code=1
            continue
        fi

        echo "Removing demo '$name'..."

        # Stop container if running, starting, or building
        local remove_status
        remove_status=$(cat "$demo_dir/status" 2>/dev/null || echo "unknown")
        case "$remove_status" in
            running|starting)
                echo "  Stopping container..."
                if ! systemctl stop "systemd-nspawn@${name}.service" 2>/dev/null; then
                    echo "  Warning: Could not stop systemd-nspawn@${name}.service (may not be running, continuing removal)"
                fi
                ;;
            building|pending)
                echo "  Cancelling in-progress build..."
                ;;
        esac

        if ! systemctl disable "systemd-nspawn@${name}.service" 2>/dev/null; then
            echo "  Warning: Could not disable systemd-nspawn@${name}.service (may not be registered, continuing removal)"
        fi

        # Kill any running build and watchdog PIDs
        if [ -f "$demo_dir/build.watchdog" ]; then
            local wpid
            wpid=$(cat "$demo_dir/build.watchdog")
            if ! kill "$wpid" 2>/dev/null; then
                echo "Warning: Build watchdog PID $wpid not running (already exited)"
            fi
            rm -f "$demo_dir/build.watchdog"
        fi
        if [ -f "$demo_dir/build.pid" ]; then
            local pid
            pid=$(cat "$demo_dir/build.pid")
            if ! kill "$pid" 2>/dev/null; then
                echo "Warning: Build PID $pid not running (already exited)"
            fi
            rm -f "$demo_dir/build.pid"
        fi

        # Acquire lock for: read config → cleanup
        acquire_lock 0 || { exit_code=1; continue; }

        # Thoroughly clean up container resources (machine, veth, subvolume)
        cleanup_demo_resources "$name"

        # Remove demo state (under lock -- last step frees the IP slot)
        rm -rf "$demo_dir"

        # Clean up orphaned Let's Encrypt certificate if no other demo uses it
        local del_subdomain
        del_subdomain=$(sanitize_subdomain "${SUBDOMAIN:-$name}")
        local del_cert_path="/etc/letsencrypt/live/${del_subdomain}.iiab.io"
        if [ -d "$del_cert_path" ]; then
            # Check if any remaining demo uses the same subdomain
            local cert_in_use=false
            for other_dir in "$ACTIVE_DIR"/*/; do
                [ -d "$other_dir" ] || continue
                local other_name
                other_name=$(basename "$other_dir")
                [ "$other_name" = "$name" ] && continue
                if [ -f "$other_dir/config" ]; then
                    local other_subdomain
                    # shellcheck source=/dev/null
                    other_subdomain=$( ( source "$other_dir/config"; printf '%s' "${SUBDOMAIN:-$other_name}" ) )
                    other_subdomain=$(sanitize_subdomain "$other_subdomain")
                    if [ "$other_subdomain" = "$del_subdomain" ]; then
                        cert_in_use=true
                        break
                    fi
                fi
            done
            if ! $cert_in_use; then
                echo "  Cleaning up orphaned certificate: ${del_subdomain}.iiab.io"
                if command -v certbot >/dev/null 2>&1; then
                    certbot delete --cert-name "${del_subdomain}.iiab.io" --non-interactive >/dev/null 2>&1 || \
                        rm -rf "$del_cert_path"
                else
                    rm -rf "$del_cert_path"
                fi
            fi
        fi

        # Release lock
        release_lock

        echo "Demo '$name' deleted."
    done

    # Reload systemd and regenerate nginx once after all deletions
    systemctl daemon-reload
    if [ -x "$SCRIPT_DIR/nginx-gen.sh" ]; then
        bash "$SCRIPT_DIR/nginx-gen.sh"
    fi

    return $exit_code
}

###############################################################################
# democtl rebuild
###############################################################################
cmd_rebuild() {
    ensure_root "$@"

    local rebuild_all=false
    local names=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all) rebuild_all=true; shift ;;
            *) names+=("$1"); shift ;;
        esac
    done

    if $rebuild_all; then
        # Pokeyoke: acquire lock for the entire rebuild --all operation
        # This is critical -- it stops ALL demos, deletes storage, and rebuilds everything.
        acquire_lock 0 || return 1

        # Rebuild everything from scratch: tear down all demos, recreate storage
        echo "=== Rebuilding all demos from scratch ==="
        echo "This will: stop all demos, delete storage.btrfs, redownload Debian base"
        echo ""

        # Collect all demo names
        for demo_dir in "$ACTIVE_DIR"/*/; do
            [ -d "$demo_dir" ] || continue
            names+=("$(basename "$demo_dir")")
        done

        if [ ${#names[@]} -eq 0 ]; then
            echo "No demos to rebuild."
            release_lock
            return 0
        fi

        echo "Demos to rebuild: ${names[*]}"
        echo ""

        # Phase 1: Kill any running builds/watchdogs first
        echo "=== Cancelling in-progress builds ==="
        for name in "${names[@]}"; do
            local demo_dir="$ACTIVE_DIR/$name"
            [ -d "$demo_dir" ] || continue
            if [ -f "$demo_dir/build.watchdog" ]; then
                local wpid
                wpid=$(cat "$demo_dir/build.watchdog" 2>/dev/null || true)
                if [ -n "$wpid" ]; then
                    echo "  Killing build watchdog for $name (PID $wpid)..."
                    kill "$wpid" 2>/dev/null || true
                fi
                rm -f "$demo_dir/build.watchdog"
            fi
            if [ -f "$demo_dir/build.pid" ]; then
                local pid
                pid=$(cat "$demo_dir/build.pid" 2>/dev/null || true)
                if [ -n "$pid" ]; then
                    echo "  Killing build process for $name (PID $pid)..."
                    kill "$pid" 2>/dev/null || true
                fi
                rm -f "$demo_dir/build.pid"
            fi
        done

        # Phase 2: Stop all running/starting containers with a timeout
        echo ""
        echo "=== Stopping all containers ==="
        for name in "${names[@]}"; do
            local demo_dir="$ACTIVE_DIR/$name"
            [ -d "$demo_dir" ] || continue
            local status
            status=$(cat "$demo_dir/status" 2>/dev/null || echo "unknown")
            case "$status" in
                running|starting)
                    echo -n "  Stopping $name... "
                    systemctl stop "systemd-nspawn@${name}.service" 2>/dev/null &
                    local stop_pid=$!
                    # Wait up to 30s for graceful stop
                    local waited=0
                    while kill -0 "$stop_pid" 2>/dev/null && [ "$waited" -lt 30 ]; do
                        sleep 1
                        waited=$((waited + 1))
                    done
                    if kill -0 "$stop_pid" 2>/dev/null; then
                        echo "(timeout after 30s, force-killing)"
                        kill -9 "$stop_pid" 2>/dev/null || true
                        wait "$stop_pid" 2>/dev/null || true
                        # Also kill the container directly
                        machinectl terminate "$name" 2>/dev/null || true
                    else
                        echo "done."
                    fi
                    ;;
                building|pending)
                    echo "  $name is still building (terminating)..."
                    machinectl terminate "$name" 2>/dev/null || true
                    ;;
            esac
        done
        # Reap any remaining stop processes
        wait 2>/dev/null || true

        # Phase 3: Disable all services
        for name in "${names[@]}"; do
            systemctl disable "systemd-nspawn@${name}.service" 2>/dev/null || true
        done

        # Phase 4: Unmount storage and delete btrfs files
        echo ""
        echo "=== Tearing down storage ==="
        for STORAGE_ROOT in /run/iiab-demos/storage /var/iiab-demos/storage; do
            if mountpoint -q "$STORAGE_ROOT" 2>/dev/null; then
                echo "  Unmounting $STORAGE_ROOT..."
                umount -l "$STORAGE_ROOT" 2>/dev/null || true
            fi
        done
        # Wait briefly for lazy unmounts to settle
        sleep 1
        # Remove storage.btrfs from both RAM and disk (whichever exists)
        if [ -f /run/iiab-demos/storage.btrfs ]; then
            echo "  Removing /run/iiab-demos/storage.btrfs (RAM)..."
            rm -f /run/iiab-demos/storage.btrfs
        fi
        if [ -f /var/iiab-demos/storage.btrfs ]; then
            echo "  Removing /var/iiab-demos/storage.btrfs (disk)..."
            rm -f /var/iiab-demos/storage.btrfs
        fi
        rm -rf /run/iiab-demos/storage /var/iiab-demos/storage
        echo "  Storage deleted."

        # Remove all demo state
        echo ""
        echo "=== Removing all demo state ==="
        for name in "${names[@]}"; do
            if [ -z "$name" ]; then
                echo "  Warning: empty demo name, skipping"
                continue
            fi
            echo "  Removing $name..."
            rm -f "/var/lib/machines/${name:?}"
            rm -f "/etc/systemd/nspawn/${name:?}.nspawn"
            rm -rf "/etc/systemd/system/systemd-nspawn@${name:?}.service.d"
            rm -rf "$ACTIVE_DIR/${name:?}"
        done

        # Reset resource counters
        if [ -f "$RESOURCE_FILE" ]; then
            echo "DISK_ALLOCATED=0" > "$RESOURCE_FILE"
            echo "DISK_TOTAL=0" >> "$RESOURCE_FILE"
            echo "  Resource counters reset."
        fi

        echo ""
        echo "=== Rebuilding all demos ==="
        echo ""

        local exit_code=0
        # Rebuild each demo (without --all, so they don't recurse)
        for name in "${names[@]}"; do
            echo "========================================"
            echo "Rebuilding: $name"
            echo "========================================"
            cmd_build "$name" || exit_code=1
        done

        # Reload systemd and regenerate nginx once after all rebuilds
        systemctl daemon-reload
        if [ -x "$SCRIPT_DIR/nginx-gen.sh" ]; then
            bash "$SCRIPT_DIR/nginx-gen.sh"
        fi

        release_lock
        return $exit_code
    fi

    # Normal rebuild: specific demos
    if [ ${#names[@]} -eq 0 ]; then
        echo "Error: at least one demo name required, or use --all to rebuild everything" >&2
        echo "Usage: democtl rebuild <name> [name ...]" >&2
        echo "       democtl rebuild --all" >&2
        return 1
    fi

    local exit_code=0
    for name in "${names[@]}"; do
        local demo_dir="$ACTIVE_DIR/$name"
        if [ ! -d "$demo_dir" ] || [ ! -f "$demo_dir/config" ]; then
            echo "Error: demo '$name' not found" >&2
            exit_code=1
            continue
        fi

        # Extract values before removal.
        local IIAB_BRANCH IIAB_REPO IMAGE_SIZE_MB VOLATILE_MODE BUILD_ON_DISK SKIP_INSTALL LOCAL_VARS WILDCARD DESCRIPTION BASE_NAME
        eval "$( (
            # shellcheck source=/dev/null
            source "$demo_dir/config"
            for _rebuild_var in IIAB_BRANCH IIAB_REPO IMAGE_SIZE_MB VOLATILE_MODE BUILD_ON_DISK SKIP_INSTALL LOCAL_VARS WILDCARD DESCRIPTION BASE_NAME; do
                printf '%s=%q\n' "$_rebuild_var" "${!_rebuild_var:-}"
            done
        ) )"

        cmd_delete "$name" || { exit_code=1; continue; }

        # Re-add with saved config
        local add_args=("$name")
        [ -n "${IIAB_BRANCH:-}" ] && add_args+=("--branch" "$IIAB_BRANCH")
        [ -n "${IIAB_REPO:-}" ] && add_args+=("--repo" "$IIAB_REPO")
        [ -n "${IMAGE_SIZE_MB:-}" ] && add_args+=("--size" "$IMAGE_SIZE_MB")
        [ -n "${VOLATILE_MODE:-}" ] && add_args+=("--volatile" "$VOLATILE_MODE")
        [ "${BUILD_ON_DISK:-false}" = "true" ] && add_args+=("--build-on-disk")
        [ "${SKIP_INSTALL:-false}" = "true" ] && add_args+=("--skip-install")
        [ -n "${LOCAL_VARS:-}" ] && add_args+=("--local-vars" "$LOCAL_VARS")
        [ "${WILDCARD:-false}" = "true" ] && add_args+=("--wildcard")
        [ -n "${DESCRIPTION:-}" ] && add_args+=("--description" "$DESCRIPTION")
        [ -n "${BASE_NAME:-}" ] && add_args+=("--base" "$BASE_NAME")

        cmd_build "${add_args[@]}" || exit_code=1
    done
    return $exit_code
}

###############################################################################
# democtl list
###############################################################################
cmd_list() {
    ensure_root "$@"
    ensure_state_dirs

    # Load resources
    load_resources

    printf "%-15s %-20s %-12s %-10s %-10s %s\n" \
        "NAME" "SUBDOMAIN" "IP" "STATUS" "SIZE/MB" "DESCRIPTION"
    printf "%-15s %-20s %-12s %-10s %-10s %s\n" \
        "----" "---------" "--" "------" "-------" "-----------"

    local total_disk_used=0
    for demo_dir in "$ACTIVE_DIR"/*/; do
        [ -d "$demo_dir" ] || continue
        local name
        name=$(basename "$demo_dir")
        # shellcheck source=/dev/null
        source "$demo_dir/config"
        local ip
        ip=$(cat "$demo_dir/ip" 2>/dev/null || echo "?")
        local status
        status=$(cat "$demo_dir/status" 2>/dev/null || echo "unknown")
        local size_display="${IMAGE_SIZE_MB}M"
        total_disk_used=$(( total_disk_used + IMAGE_SIZE_MB ))
        local desc="${DESCRIPTION:--}"
        local list_subdomain
        list_subdomain=$(sanitize_subdomain "${SUBDOMAIN:-$name}")
        printf "%-15s %-20s %-12s %-10s %-10s %s\n" \
            "$name" "${list_subdomain}.iiab.io" "$ip" "$status" "$size_display" "$desc"
    done

    echo ""
    echo "Resources: ${DISK_ALLOCATED}MB allocated, ${DISK_TOTAL}MB total"
}

###############################################################################
# democtl status
###############################################################################
cmd_status() {
    ensure_root "$@"
    if [ $# -eq 0 ]; then
        echo "Error: at least one demo name required" >&2
        echo "Usage: democtl status <name> [name ...]" >&2
        return 1
    fi

    local exit_code=0
    for name in "$@"; do
        local demo_dir="$ACTIVE_DIR/$name"

        if [ ! -d "$demo_dir" ]; then
            echo "Error: demo '$name' not found" >&2
            exit_code=1
            continue
        fi

        # shellcheck source=/dev/null
        source "$demo_dir/config"
        local ip
        ip=$(cat "$demo_dir/ip")
        local status
        status=$(cat "$demo_dir/status" 2>/dev/null || echo "unknown")

        echo "=== Demo: $name ==="
        local status_subdomain
        status_subdomain=$(sanitize_subdomain "${SUBDOMAIN:-$name}")
        echo "Subdomain:  ${status_subdomain}.iiab.io"
        echo "Branch:     $IIAB_BRANCH"
        echo "Repo:       $IIAB_REPO"
        echo "IP:         $ip"
        echo "Status:     $status"
        echo "Volatile:   $VOLATILE_MODE"
        echo "Size:       ${IMAGE_SIZE_MB}MB"
        if [ -n "$DESCRIPTION" ]; then
            echo "Description: $DESCRIPTION"
        fi

        if [ "$status" = "running" ]; then
            echo ""
            systemctl status "systemd-nspawn@${name}.service" --no-pager || true
        fi

        # Show certificate expiry info
        local subdomain
        subdomain=$(sanitize_subdomain "${SUBDOMAIN:-$name}" 2>/dev/null || echo "${SUBDOMAIN:-$name}")
        local cert_path="/etc/letsencrypt/live/${subdomain}.iiab.io/fullchain.pem"
        if [ -f "$cert_path" ]; then
            local cert_expiry
            cert_expiry=$(openssl x509 -enddate -noout -in "$cert_path" 2>/dev/null | cut -d= -f2 || echo "")
            if [ -n "$cert_expiry" ]; then
                local expiry_epoch now days_left
                expiry_epoch=$(date -d "$cert_expiry" +%s 2>/dev/null || echo 0)
                now=$(date +%s)
                if [ "$expiry_epoch" -gt 0 ]; then
                    days_left=$(( (expiry_epoch - now) / 86400 ))
                    echo ""
                    echo "Certificate: $cert_path"
                    echo "  Expires: $cert_expiry"
                    if [ "$days_left" -lt 0 ]; then
                        echo "  Status: EXPIRED ($(( -days_left )) days ago)"
                    elif [ "$days_left" -lt 7 ]; then
                        echo "  Status: WARNING -- expires in $days_left days"
                    else
                        echo "  Status: OK ($days_left days remaining)"
                    fi
                fi
            fi
        elif [ "$status" = "running" ]; then
            echo ""
            echo "Certificate: not obtained (run: democtl certbot)"
        fi

        if [ "$status" = "building" ] && [ -f "$demo_dir/build.pid" ]; then
            local pid
            pid=$(cat "$demo_dir/build.pid")
            echo ""
            echo "Build PID: $pid"
            if kill -0 "$pid" 2>/dev/null; then
                echo "Build is still running..."
            else
                echo "Build process has exited (check log)"
            fi

            # Show watchdog info
            if [ -f "$demo_dir/build.watchdog" ]; then
                local wpid
                wpid=$(cat "$demo_dir/build.watchdog")
                if kill -0 "$wpid" 2>/dev/null; then
                    echo "Watchdog PID: $wpid (monitoring)"
                else
                    echo "Watchdog PID: $wpid (exited)"
                fi
            fi

            # Check for hung build (no log output in 30+ minutes)
            if [ -f "$demo_dir/build.log" ]; then
                local log_mtime now age_sec
                log_mtime=$(stat -c%Y "$demo_dir/build.log" 2>/dev/null || echo 0)
                now=$(date +%s)
                age_sec=$(( now - log_mtime ))
                if [ "$age_sec" -gt 1800 ]; then
                    echo ""
                    echo "WARNING: Build log hasn't been updated for $(( age_sec / 60 )) minutes."
                    echo "  The build may be hung. Consider: democtl delete $name"
                fi
            fi
        fi

        # Separate output for multiple demos
        if [ $# -gt 1 ]; then
            echo ""
        fi
    done
    return $exit_code
}

###############################################################################
# democtl logs
###############################################################################
cmd_logs() {
    ensure_root "$@"
    if [ $# -eq 0 ]; then
        echo "Error: at least one demo name required" >&2
        echo "Usage: democtl logs <name> [name ...]" >&2
        return 1
    fi

    local exit_code=0
    for name in "$@"; do
        local demo_dir="$ACTIVE_DIR/$name"

        if [ ! -d "$demo_dir" ]; then
            echo "Error: demo '$name' not found" >&2
            exit_code=1
            continue
        fi

        local status
        status=$(cat "$demo_dir/status" 2>/dev/null || echo "unknown")

        if [ "$status" = "running" ]; then
            journalctl -u "systemd-nspawn@${name}.service" -e --no-pager
        elif [ -f "$demo_dir/build.log" ]; then
            echo "=== Build log for '$name' ==="
            tail -100 "$demo_dir/build.log"
        else
            echo "No logs available for '$name'"
        fi

        # Separate output for multiple demos
        if [ $# -gt 1 ]; then
            echo ""
        fi
    done
    return $exit_code
}

###############################################################################
# democtl shell
###############################################################################
cmd_shell() {
    ensure_root "$@"
    local name="${1:?Error: demo name required}"

    if [ ! -d "$ACTIVE_DIR/$name" ]; then
        echo "Error: demo '$name' not found" >&2
        return 1
    fi

    local shell_status
    shell_status=$(cat "$ACTIVE_DIR/$name/status" 2>/dev/null || echo "unknown")
    if [ "$shell_status" != "running" ]; then
        echo "Error: demo '$name' is not running (status: $shell_status)" >&2
        echo "  Start it first: democtl start $name" >&2
        return 1
    fi

    # Use systemd-run for shell, as machinectl shell is essentially a wrapper around it
    systemd-run -it --machine="$name" /bin/bash
}

###############################################################################
# democtl settle -- wait until all demos reach a settled state
###############################################################################
cmd_settle() {
    ensure_root "$@"
    local timeout="${1:-3600}"  # Default: wait up to 60 minutes
    ensure_state_dirs

    echo "=== Waiting for all demos to reach a settled state ==="
    echo "  Settled states: running, stopped, failed"
    echo "  Timeout: ${timeout}s"

    local start_time
    start_time=$(date +%s)
    local poll_interval=10

    while true; do
        local now
        now=$(date +%s)
        local elapsed=$(( now - start_time ))

        if [ "$elapsed" -ge "$timeout" ]; then
            echo ""
            echo "Error: Timed out after ${timeout}s waiting for demos to settle." >&2
            echo "  Some demos may still be in transition. Check with: democtl list" >&2
            return 1
        fi

        local all_settled=true
        local in_progress=()
        local failed=()
        local running=0
        local stopped=0

        for demo_dir in "$ACTIVE_DIR"/*/; do
            [ -d "$demo_dir" ] || continue
            local name
            name=$(basename "$demo_dir")
            local status
            status=$(cat "$demo_dir/status" 2>/dev/null || echo "unknown")

            case "$status" in
                running)
                    running=$((running + 1))
                    ;;
                stopped)
                    stopped=$((stopped + 1))
                    ;;
                failed)
                    failed+=("$name")
                    ;;
                pending|building|starting|stopping)
                    all_settled=false
                    in_progress+=("$name")
                    ;;
                *)
                    all_settled=false
                    in_progress+=("$name")
                    ;;
            esac
        done

        # Show progress
        local total=$(( running + stopped + ${#in_progress[@]} + ${#failed[@]} ))
        if [ "$total" -eq 0 ]; then
            echo "No demos found. Nothing to settle."
            return 0
        fi

        echo -ne "\r  Running: $running | Stopped: $stopped | In Progress: ${#in_progress[@]} | Failed: ${#failed[@]} | Elapsed: ${elapsed}s  "

        if $all_settled; then
            echo ""
            echo ""
            if [ ${#failed[@]} -gt 0 ]; then
                echo "Demos have settled -- some failed."
                echo "  Running: $running"
                echo "  Stopped: $stopped"
                echo "  Failed: ${failed[*]}"
                return 1
            else
                echo "All demos have settled."
                echo "  Running: $running"
                echo "  Stopped: $stopped"
                return 0
            fi
        fi

        sleep "$poll_interval"
    done
}

###############################################################################
# democtl reconcile -- fix drift in allocated resource counters
###############################################################################
cmd_reconcile() {
    ensure_root "$@"
    ensure_state_dirs

    echo "=== Reconciling resource counters ==="

    acquire_lock 0 || {
        echo "Error: another operation is in progress" >&2
        return 1
    }

    # load_resources dynamically calculates allocations from active configs
    load_resources
    save_resources

    release_lock

    echo "Reconciled resource allocations from active demos."
    echo "  Disk allocated: ${DISK_ALLOCATED}MB"

    # Check for ghost IPs (IPs assigned but no running container)
    echo ""
    echo "=== Checking for ghost IP assignments ==="
    local ghosts=0
    for demo_dir in "$ACTIVE_DIR"/*/; do
        [ -d "$demo_dir" ] || continue
        local name
        name=$(basename "$demo_dir")
        local ip=""
        if [ -f "$demo_dir/ip" ]; then
            ip=$(cat "$demo_dir/ip")
        fi
        local status=""
        if [ -f "$demo_dir/status" ]; then
            status=$(cat "$demo_dir/status")
        fi
        if [ "$status" != "running" ] && [ -n "$ip" ]; then
            echo "  Ghost: $name has IP $ip but status is '$status'"
            ghosts=$((ghosts + 1))
        fi
    done
    if [ "$ghosts" -eq 0 ]; then
        echo "  No ghost IP assignments found."
    fi
}

###############################################################################
# democtl reload -- regenerate nginx
###############################################################################
cmd_reload() {
    ensure_root "$@"
    if [ -x "$SCRIPT_DIR/nginx-gen.sh" ]; then
