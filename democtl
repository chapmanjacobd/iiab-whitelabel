    load_resources

    printf "%-15s %-20s %-12s %-10s %-10s %s\n" \
        "NAME" "SUBDOMAIN" "IP" "STATUS" "RAM/MB" "DESCRIPTION"
    printf "%-15s %-20s %-12s %-10s %-10s %s\n" \
        "----" "---------" "--" "------" "------" "-----------"

    local total_ram_used=0
    for demo_dir in "$ACTIVE_DIR"/*/; do
        [ -d "$demo_dir" ] || continue
        local name
        name=$(basename "$demo_dir")
        # shellcheck source=/dev/null
        source "$demo_dir/config"
        local ip
        ip=$(cat "$demo_dir/ip" 2>/dev/null || echo "?")
        local status
        status=$(cat "$demo_dir/status" 2>/dev/null || echo "unknown")
        local ram_display="-"
        if [ "$RAM_IMAGE" = "true" ]; then
            ram_display="${IMAGE_SIZE_MB}M"
            total_ram_used=$(( total_ram_used + IMAGE_SIZE_MB ))
        fi
        local desc="${DESCRIPTION:--}"
        local list_subdomain
        list_subdomain=$(sanitize_subdomain "${SUBDOMAIN:-$name}")
        printf "%-15s %-20s %-12s %-10s %-10s %s\n" \
            "$name" "${list_subdomain}.iiab.io" "$ip" "$status" "$ram_display" "$desc"
    done

    echo ""
    echo "Resources: ${RAM_ALLOCATED}MB/${RAM_TOTAL}MB RAM allocated, ${DISK_ALLOCATED}MB disk"
