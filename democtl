###############################################################################
# democtl shutdown
###############################################################################
cmd_shutdown() {
    ensure_root "$@"
    local name="${1:?Error: demo name required}"

    local demo_dir="$ACTIVE_DIR/$name"
    if [ ! -d "$demo_dir" ]; then
        echo "Error: demo '$name' not found" >&2
        return 1
    fi

    local status
    status=$(cat "$demo_dir/status" 2>/dev/null || echo "unknown")

    if [ "$status" != "running" ]; then
        echo "Error: demo '$name' is not running (status: $status)" >&2
        return 1
    fi

    echo "Shutting down demo '$name'..."
    systemctl stop "systemd-nspawn@${name}.service" 2>/dev/null || true
    systemctl disable "systemd-nspawn@${name}.service" 2>/dev/null || true
    echo "stopped" > "$demo_dir/status"
    echo "Demo '$name' has been shut down."
}

###############################################################################
# democtl boot
###############################################################################
cmd_boot() {
    ensure_root "$@"
    local name="${1:?Error: demo name required}"

    local demo_dir="$ACTIVE_DIR/$name"
    if [ ! -d "$demo_dir" ]; then
        echo "Error: demo '$name' not found" >&2
        return 1
    fi

    local status
    status=$(cat "$demo_dir/status" 2>/dev/null || echo "unknown")

    if [ "$status" = "running" ]; then
        echo "Error: demo '$name' is already running" >&2
        return 1
    fi

    # Ensure image symlink exists
    if [ -f "/run/iiab-ramfs/${name}.raw" ]; then
        ln -sf "/run/iiab-ramfs/${name}.raw" "/var/lib/machines/${name}.raw"
    fi

    if [ ! -f "/var/lib/machines/${name}.raw" ]; then
        echo "Error: Image not found for demo '$name'" >&2
        return 1
    fi

    echo "Booting demo '$name'..."
    systemctl enable --now "systemd-nspawn@${name}.service"

    # Poll for actual container startup
    sleep 3
    local poll_count=0
    local poll_max=15
    while [ $poll_count -lt $poll_max ]; do
        if systemctl is-active --quiet "machine-${name}.service" 2>/dev/null || \
           systemctl is-active --quiet "systemd-nspawn@${name}.service" 2>/dev/null; then
            break
        fi
        poll_count=$((poll_count + 1))
        sleep 1
    done

    if [ $poll_count -eq $poll_max ]; then
        echo "Error: Container did not become active within ${poll_max}s" >&2
        return 1
    fi

    echo "running" > "$demo_dir/status"
    echo "Demo '$name' is now running!"
}

###############################################################################
# democtl reboot
###############################################################################
cmd_reboot() {
    ensure_root "$@"
    local name="${1:?Error: demo name required}"

    local demo_dir="$ACTIVE_DIR/$name"
    if [ ! -d "$demo_dir" ]; then
        echo "Error: demo '$name' not found" >&2
        return 1
    fi

    local status
    status=$(cat "$demo_dir/status" 2>/dev/null || echo "unknown")

    if [ "$status" != "running" ]; then
        echo "Error: demo '$name' is not running (status: $status)" >&2
        return 1
    fi

    echo "Rebooting demo '$name'..."
    systemctl restart "systemd-nspawn@${name}.service"

    # Poll for actual container startup
    sleep 3
    local poll_count=0
    local poll_max=15
    while [ $poll_count -lt $poll_max ]; do
        if systemctl is-active --quiet "machine-${name}.service" 2>/dev/null || \
           systemctl is-active --quiet "systemd-nspawn@${name}.service" 2>/dev/null; then
            break
        fi
        poll_count=$((poll_count + 1))
        sleep 1
    done

    if [ $poll_count -eq $poll_max ]; then
        echo "Error: Container did not become active within ${poll_max}s after reboot" >&2
        return 1
    fi

    echo "Demo '$name' has been rebooted and is running!"
}

###############################################################################
# democtl help
###############################################################################
cmd_help() {
    cat << 'EOF'
democtl - Manage IIAB whitelabel demo containers

Usage: democtl <command> [args]

Commands:
  init                          Bootstrap host (install packages, network, nginx)
  add <name> [flags]            Add a demo (builds in background by default)
  remove <name>                 Stop and delete a demo
  rebuild <name>                Remove and re-add a demo
  list                          Show all demos
  status <name>                 Detailed status for a demo
  logs <name>                   Show build log or container journal
  shell <name>                  Open shell in container
  shutdown <name>               Stop a running demo
  boot <name>                   Start a stopped demo
  reboot <name>                 Restart a running demo
  reload                        Regenerate nginx config from active demos
  ramfs <action> [name]         Manage RAM-loaded images (load/unload/status/cleanup)
  reconcile                     Fix resource counter drift and check ghost IPs

Add flags:
  --repo <url>              IIAB git repo (default: github.com/iiab/iiab.git)
  --branch <ref>            Git branch/tag/ref (default: master)
  --size <MB>               Image size (default: 15000)
  --disk-backed             Keep image on disk instead of RAM (default: no)
  --volatile <mode>         no | yes | state (default: state)
  --local-vars <path>       Path to local_vars.yml (relative to IIAB repo in container)
  --wildcard                Use as wildcard for unknown subdomains
  --description <text>      Human-readable description
  --build-on-disk           Build on disk instead of RAM (default: build in RAM)
  --fg                      Build in foreground (default: background)

Examples:
  democtl init
  democtl add small --local-vars vars/local_vars_small.yml --size 12000
  democtl add pr3612 --local-vars vars/local_vars_large.yml --branch refs/pull/3612/head --volatile yes
  democtl list
  democtl status small
  democtl shutdown small
  democtl boot small
  democtl reboot small
  democtl remove pr3612
EOF
}

###############################################################################
# Main dispatch
###############################################################################
main() {
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        init)      cmd_init "$@" ;;
        add)       cmd_add "$@" ;;
        remove)    cmd_remove "$@" ;;
        rebuild)   cmd_rebuild "$@" ;;
        list)      cmd_list "$@" ;;
        status)    cmd_status "$@" ;;
        logs)      cmd_logs "$@" ;;
        shell)     cmd_shell "$@" ;;
        shutdown)  cmd_shutdown "$@" ;;
        boot)      cmd_boot "$@" ;;
        reboot)    cmd_reboot "$@" ;;
        reload)    cmd_reload "$@" ;;
        ramfs)     cmd_ramfs "$@" ;;
        reconcile) cmd_reconcile "$@" ;;
        help|--help|-h) cmd_help ;;
        *)
            echo "Error: Unknown command: $cmd" >&2
            echo "Run 'democtl help' for usage" >&2
            return 1
            ;;
    esac
}

main "$@"
